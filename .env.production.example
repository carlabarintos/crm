# ── Hostname ──────────────────────────────────────────────────────────────────
# Use <IP>.nip.io until you have a real domain.
# Example: if your Hetzner IP is 49.13.12.34, set DOMAIN=49.13.12.34.nip.io
# When you get a real domain, update this value and restart.
DOMAIN=1.2.3.4.nip.io

# ── GitHub ────────────────────────────────────────────────────────────────────
# Your GitHub username or organisation — used to pull images from ghcr.io
GITHUB_OWNER=carlabarintos

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=crm

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=crm
RABBITMQ_DEFAULT_PASS=change_me

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
