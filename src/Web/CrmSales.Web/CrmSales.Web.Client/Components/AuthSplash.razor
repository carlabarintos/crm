@* Full-screen branded splash shown during login / logout flows *@
<div class="auth-splash">
    <div class="auth-splash-card">

        <div class="auth-brand">
            <div class="auth-brand-icon">
                @if (Icon == "logout")
                {
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path d="M8 4H5a2 2 0 00-2 2v12a2 2 0 002 2h3M15 15l4-4-4-4M19 11H9"
                              stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                }
                else
                {
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path d="M3 16L8 9.5L12.5 13L17 7" stroke="white" stroke-width="2.2"
                              stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx="17" cy="7" r="2.5" fill="white" />
                    </svg>
                }
            </div>
            <div>
                <div class="auth-brand-name">CRM Sales</div>
                <div class="auth-brand-tagline">Sales Pipeline</div>
            </div>
        </div>

        <div class="auth-dots">
            <span class="auth-dot"></span>
            <span class="auth-dot"></span>
            <span class="auth-dot"></span>
        </div>

        <div class="auth-message">@Message</div>
        <div class="auth-sub">@Sub</div>
    </div>
</div>

@code {
    [Parameter] public string Message { get; set; } = "Loading";
    [Parameter] public string Sub { get; set; } = "Please wait…";
    [Parameter] public string Icon { get; set; } = "login";
}

<style>
    .auth-splash {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(ellipse at 60% 40%, #eef2ff 0%, #f8fafc 55%, #f0fdf4 100%);
        z-index: 9999;
    }

    .auth-splash-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 3rem 3.5rem;
        background: white;
        border: 1px solid #E5E7EB;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(79,70,229,.10), 0 2px 8px rgba(0,0,0,.05);
        animation: splashIn .45s cubic-bezier(.16,1,.3,1) both;
        min-width: 320px;
        text-align: center;
    }

    .auth-brand {
        display: flex;
        align-items: center;
        gap: .875rem;
    }

    .auth-brand-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(79,70,229,.35);
        flex-shrink: 0;
    }

    .auth-brand-name {
        font-size: 17px;
        font-weight: 800;
        color: #111827;
        letter-spacing: -.03em;
        line-height: 1.1;
    }

    .auth-brand-tagline {
        font-size: 11.5px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
    }

    .auth-dots {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .auth-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #4F46E5;
        animation: dotPulse 1.4s ease-in-out infinite;
    }
    .auth-dot:nth-child(2) { animation-delay: .2s; background: #7C3AED; }
    .auth-dot:nth-child(3) { animation-delay: .4s; background: #A855F7; }

    .auth-message {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        letter-spacing: -.02em;
        margin-bottom: -.5rem;
    }

    .auth-sub {
        font-size: 13px;
        color: #6B7280;
        font-weight: 400;
        max-width: 240px;
    }

    @@keyframes dotPulse {
        0%, 80%, 100% { transform: scale(.6); opacity: .35; }
        40%            { transform: scale(1);  opacity: 1;   }
    }

    @@keyframes splashIn {
        from { opacity: 0; transform: scale(.96) translateY(8px); }
        to   { opacity: 1; transform: scale(1)   translateY(0);   }
    }
</style>
