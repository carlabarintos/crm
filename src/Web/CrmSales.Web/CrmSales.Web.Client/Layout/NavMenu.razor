@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject SignOutSessionStateManager SignOutManager
@implements IDisposable

@code {
    private string? _userName;
    private string? _userEmail;

    protected override void OnInitialized()
        => AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;

    protected override async Task OnInitializedAsync()
        => await LoadUserAsync(await AuthStateProvider.GetAuthenticationStateAsync());

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        await LoadUserAsync(await task);
        await InvokeAsync(StateHasChanged);
    }

    private Task LoadUserAsync(AuthenticationState auth)
    {
        var user = auth.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.FindFirst("preferred_username")?.Value
                ?? user.FindFirst("name")?.Value
                ?? user.Identity.Name;
            _userEmail = user.FindFirst("email")?.Value;
        }
        else
        {
            _userName = null;
            _userEmail = null;
        }
        return Task.CompletedTask;
    }

    private bool _menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private async Task SignOut()
    {
        await SignOutManager.SetSignOutState();
        Navigation.NavigateTo("authentication/logout");
    }

    public void Dispose()
        => AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;

    private static string GetInitial(string? name)
        => string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();
}
