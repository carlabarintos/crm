@inherits LayoutComponentBase
@using CrmSales.Web.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject NotificationService NotifSvc
@inject AuthenticationStateProvider AuthState
@implements IAsyncDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <div class="main-panel">
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-search-wrap">
                    <svg class="search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="6" cy="6" r="4.5" />
                        <path d="M10 10L13 13" stroke-linecap="round" />
                    </svg>
                    <input type="text" placeholder="Search deals, contacts…" class="topbar-search" />
                    <kbd class="search-kbd">⌘K</kbd>
                </div>
            </div>
            <div class="topbar-right">
                <!-- Notification bell -->
                <div class="notif-bell-wrap">
                    <button class="topbar-icon-btn" title="Notifications" @onclick="ToggleBell">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M8 2a4 4 0 0 1 4 4c0 4 1.5 5 1.5 5H2.5S4 10 4 6a4 4 0 0 1 4-4z" stroke-linecap="round" />
                            <path d="M6.5 13a1.5 1.5 0 0 0 3 0" stroke-linecap="round" />
                        </svg>
                        @if (NotifSvc.UnreadCount > 0)
                        {
                            <span class="notif-badge">@(NotifSvc.UnreadCount > 9 ? "9+" : NotifSvc.UnreadCount)</span>
                        }
                        else
                        {
                            <span class="notif-dot"></span>
                        }
                    </button>

                    @if (_bellOpen)
                    {
                        <div class="notif-backdrop" @onclick="CloseBell"></div>
                        <div class="notif-dropdown">
                            <div class="notif-dropdown-header">
                                <span>Notifications</span>
                                @if (NotifSvc.UnreadCount > 0)
                                {
                                    <button class="notif-mark-read" @onclick="MarkRead">Mark all read</button>
                                }
                            </div>
                            <div class="notif-list">
                                @if (!NotifSvc.Recent.Any())
                                {
                                    <div class="notif-empty">No notifications yet</div>
                                }
                                @foreach (var n in NotifSvc.Recent)
                                {
                                    <div class="notif-item @GetNotifClass(n.Type)">
                                        <div class="notif-item-title">@n.Title</div>
                                        <div class="notif-item-msg">@n.Message</div>
                                        <div class="notif-item-time">@FormatTime(n.OccurredAt)</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <button class="topbar-icon-btn" title="Help">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="8" cy="8" r="6.5" />
                        <path d="M6 6.5a2 2 0 1 1 2.5 1.9c-.5.15-.5.6-.5 1.1" stroke-linecap="round" />
                        <circle cx="8" cy="12" r=".75" fill="currentColor" stroke="none" />
                    </svg>
                </button>
                <div class="topbar-divider"></div>
                <a href="/opportunities/new" class="btn-new-deal">+ New Deal</a>
            </div>
        </header>
        <main>
            <article class="content">
                @Body
            </article>
        </main>
    </div>
</div>

<!-- Toast notifications (bottom-right) -->
<div class="toast-stack">
    @foreach (var t in _toasts)
    {
        <div class="toast-item toast-@GetToastColor(t.Type)">
            <div class="toast-title">@t.Title</div>
            <div class="toast-msg">@t.Message</div>
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#10006;</span>
</div>

<style>
    .notif-bell-wrap { position: relative; }

    .notif-badge {
        position: absolute;
        top: 2px; right: 2px;
        min-width: 16px; height: 16px;
        background: #EF4444;
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        border-radius: 99px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 3px;
        line-height: 1;
    }

    .notif-backdrop {
        position: fixed;
        inset: 0;
        z-index: 999;
    }

    .notif-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 320px;
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        z-index: 1000;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: 420px;
    }

    .notif-list {
        overflow-y: auto;
        flex: 1;
    }
    .notif-dropdown-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid #F3F4F6;
        font-size: 13px;
        font-weight: 600;
        color: #111827;
    }
    .notif-mark-read {
        font-size: 11px;
        color: #6B7280;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }
    .notif-mark-read:hover { color: #4F46E5; }
    .notif-empty {
        padding: 24px 16px;
        text-align: center;
        font-size: 13px;
        color: #9CA3AF;
    }
    .notif-item {
        padding: 10px 16px;
        border-bottom: 1px solid #F9FAFB;
        border-left: 3px solid transparent;
    }
    .notif-item:last-child { border-bottom: none; }
    .notif-item-green  { border-left-color: #10B981; }
    .notif-item-blue   { border-left-color: #3B82F6; }
    .notif-item-yellow { border-left-color: #F59E0B; }
    .notif-item-red    { border-left-color: #EF4444; }
    .notif-item-purple { border-left-color: #8B5CF6; }
    .notif-item-title  { font-size: 12px; font-weight: 600; color: #111827; margin-bottom: 2px; }
    .notif-item-msg    { font-size: 12px; color: #4B5563; line-height: 1.4; }
    .notif-item-time   { font-size: 10.5px; color: #9CA3AF; margin-top: 4px; }

    /* Toast stack */
    .toast-stack {
        position: fixed;
        bottom: 24px; right: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 2000;
        pointer-events: none;
    }
    .toast-item {
        min-width: 280px;
        max-width: 340px;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,.14);
        padding: 12px 16px;
        border-left: 4px solid #6B7280;
        animation: toast-in .25s ease;
    }
    .toast-green  { border-left-color: #10B981; }
    .toast-blue   { border-left-color: #3B82F6; }
    .toast-yellow { border-left-color: #F59E0B; }
    .toast-red    { border-left-color: #EF4444; }
    .toast-purple { border-left-color: #8B5CF6; }
    .toast-title  { font-size: 13px; font-weight: 700; color: #111827; margin-bottom: 3px; }
    .toast-msg    { font-size: 12px; color: #4B5563; }
    @@keyframes toast-in {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private bool _bellOpen;
    private readonly List<NotificationEventDto> _toasts = new();
    private bool _subscribed;

    protected override async Task OnInitializedAsync()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
            EnsureStarted();
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var auth = await task;
        if (auth.User.Identity?.IsAuthenticated == true)
            EnsureStarted();
    }

    private void EnsureStarted()
    {
        if (!_subscribed)
        {
            _subscribed = true;
            NotifSvc.OnNotification += OnNewNotification;
        }
        _ = NotifSvc.StartAsync();
    }

    private void OnNewNotification(NotificationEventDto evt)
    {
        _toasts.Insert(0, evt);
        if (_toasts.Count > 5) _toasts.RemoveAt(5);
        InvokeAsync(StateHasChanged);

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            _toasts.Remove(evt);
            InvokeAsync(StateHasChanged);
        });
    }

    private void ToggleBell()
    {
        _bellOpen = !_bellOpen;
        if (_bellOpen) NotifSvc.MarkAllRead();
    }

    private void CloseBell() => _bellOpen = false;

    private void MarkRead()
    {
        NotifSvc.MarkAllRead();
        StateHasChanged();
    }

    private static string GetNotifClass(string type) => type switch
    {
        "opportunity.won"             => "notif-item-green",
        "opportunity.created"         => "notif-item-blue",
        "opportunity.stage_changed"   => "notif-item-blue",
        "quote.accepted"              => "notif-item-green",
        "quote.sent"                  => "notif-item-purple",
        "quote.created"               => "notif-item-purple",
        "quote.rejected"              => "notif-item-red",
        "order.delivered"             => "notif-item-green",
        "order.shipped"               => "notif-item-blue",
        "order.cancelled"             => "notif-item-red",
        _                             => "notif-item-yellow",
    };

    private static string GetToastColor(string type) => type switch
    {
        "opportunity.won"             => "green",
        "opportunity.created"         => "blue",
        "opportunity.stage_changed"   => "blue",
        "quote.accepted"              => "green",
        "quote.sent"                  => "purple",
        "quote.created"               => "purple",
        "quote.rejected"              => "red",
        "order.delivered"             => "green",
        "order.shipped"               => "blue",
        "order.cancelled"             => "red",
        _                             => "yellow",
    };

    private static string FormatTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d, HH:mm");
    }

    public ValueTask DisposeAsync()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
        if (_subscribed)
            NotifSvc.OnNotification -= OnNewNotification;
        return ValueTask.CompletedTask;
    }
}
