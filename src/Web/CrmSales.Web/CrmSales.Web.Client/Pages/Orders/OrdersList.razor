@page "/orders"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject IJSRuntime JS

<PageTitle>Orders — CRM Sales</PageTitle>

<div class="page-header stagger-1">
    <div>
        <p class="page-header-meta">Sales Pipeline</p>
        <h1>Orders</h1>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        @if (orders.Any())
        {
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportCsv">Export CSV</button>
        }
        <input class="form-control" style="max-width:200px" placeholder="Search orders..."
               @bind="searchTerm" @onkeyup="OnSearchKey" />
        <select class="form-select orders-desktop-filter" style="width:auto;min-width:150px" @bind="statusFilter" @bind:after="OnFilterChanged">
        <option value="">All Statuses</option>
        <option value="Pending">Pending</option>
        <option value="Confirmed">Confirmed</option>
        <option value="Processing">Processing</option>
        <option value="Shipped">Shipped</option>
        <option value="Delivered">Delivered</option>
        <option value="Cancelled">Cancelled</option>
        </select>
    </div>
</div>

<!-- Summary cards -->
@if (_summary is not null)
{
    <button type="button" class="mob-section-btn @(_statsOpen ? "open" : "")" @onclick="() => _statsOpen = !_statsOpen">
        <span>Summary</span>
        <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
    </button>
    <div class="mob-collapse @(_statsOpen ? "open" : "")">
    <div class="row g-3 mb-4 stagger-2">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Total Orders</div>
                <div class="stat-card-value" style="color:#111827">@_summary.TotalCount</div>
                <div class="stat-card-sub">all time</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Revenue</div>
                <div class="stat-card-value text-success">@FormatAmount(_summary.DeliveredRevenue, _summary.Currency)</div>
                <div class="stat-card-sub">@_summary.DeliveredCount delivered</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Active</div>
                <div class="stat-card-value" style="color:#0EA5E9">@_summary.ActiveCount</div>
                <div class="stat-card-sub">confirmed · processing · shipped</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Cancelled</div>
                <div class="stat-card-value text-danger">@_summary.CancelledCount</div>
                <div class="stat-card-sub">of @_summary.TotalCount total</div>
            </div>
        </div>
    </div>
    </div>
}

<button type="button" class="mob-section-btn @(_filtersOpen ? "open" : "")" @onclick="() => _filtersOpen = !_filtersOpen">
    <span>Filters</span>
    <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
</button>
<div class="mob-collapse @(_filtersOpen ? "open" : "")">
    <div class="mb-3">
        <input class="form-control mb-2" placeholder="Search orders..." @bind="searchTerm" @onkeyup="OnSearchKey" />
        <select class="form-select" style="width:100%" @bind="statusFilter" @bind:after="OnFilterChanged">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Processing">Processing</option>
            <option value="Shipped">Shipped</option>
            <option value="Delivered">Delivered</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
</div>

@if (orders is null && !isLoadingMore)
{
    <div class="table-responsive">
        <table class="table">
            <thead class="table-light">
                <tr>
                    <th>Order #</th><th>Status</th><th>Total</th><th>Currency</th><th>Created</th><th>Shipped</th><th>Delivered</th><th></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < 6; i++)
                {
                    var d = i * 60;
                    <tr>
                        <td><div class="lst-sk" style="width:90px;height:14px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:80px;height:20px;border-radius:99px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:80px;height:13px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:44px;height:13px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:88px;height:13px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:60px;height:13px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:60px;height:13px;animation-delay:@(d)ms"></div></td>
                        <td><div class="lst-sk" style="width:48px;height:26px;border-radius:8px;animation-delay:@(d)ms"></div></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!orders.Any())
{
    <div class="lst-empty stagger-3">
        <div class="lst-empty-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#9CA3AF" stroke-width="1.5">
                <path d="M2 2h3l2.5 13h15L25 7H7" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="10" cy="23" r="2"/><circle cx="20" cy="23" r="2"/>
            </svg>
        </div>
        <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:.35rem">No orders found</div>
        <div style="font-size:13px;color:#9CA3AF">
            @(string.IsNullOrEmpty(statusFilter) && string.IsNullOrEmpty(searchTerm) ? "Orders will appear here once quotes are accepted." : "Try adjusting your filters.")
        </div>
    </div>
}
else
{
    <div class="table-responsive stagger-3">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Order #</th><th>Status</th><th>Total</th><th>Currency</th><th>Created</th><th>Shipped</th><th>Delivered</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in orders)
                {
                    <tr>
                        <td><a href="/orders/@o.Id" class="lst-num-link">@o.OrderNumber</a></td>
                        <td><span class="badge @GetStatusBadge(o.Status)">@o.Status</span></td>
                        <td style="font-weight:600;color:#111827;font-variant-numeric:tabular-nums">@FormatAmount(o.TotalAmount, o.Currency)</td>
                        <td style="color:#6B7280">@o.Currency</td>
                        <td style="color:#6B7280;font-size:12.5px">@o.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td style="color:#6B7280;font-size:12.5px">@(o.ShippedAt?.ToString("MMM d") ?? "—")</td>
                        <td style="color:#6B7280;font-size:12.5px">@(o.DeliveredAt?.ToString("MMM d") ?? "—")</td>
                        <td><a href="/orders/@o.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (hasMore)
{
    <div class="text-center py-3">
        <button class="btn btn-outline-primary" @onclick="LoadMore" disabled="@isLoadingMore">
            @if (isLoadingMore) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Load More
        </button>
    </div>
}

<style>
    .stat-card {
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }
    .stat-card-label {
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #9CA3AF;
        margin-bottom: .3rem;
    }
    .stat-card-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
        margin-bottom: .2rem;
    }
    .stat-card-sub { font-size: 11.5px; color: #9CA3AF; }

    @@keyframes lst-shimmer {
        0%   { background-position: -400px 0; }
        100% { background-position:  400px 0; }
    }
    .lst-sk {
        background: linear-gradient(90deg, #F3F4F6 25%, #EAECF0 50%, #F3F4F6 75%);
        background-size: 800px 100%;
        animation: lst-shimmer 1.6s ease-in-out infinite;
        border-radius: 5px;
        display: inline-block;
    }
    .lst-num-link { font-weight: 600; color: #111827; text-decoration: none; }
    .lst-num-link:hover { color: #4F46E5; }
    .lst-empty {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 4rem 2rem; text-align: center;
    }
    .lst-empty-icon {
        width: 60px; height: 60px; border-radius: 16px; background: #F3F4F6;
        display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;
    }
    @@media (max-width: 640.98px) {
        .orders-desktop-filter { display: none; }
    }
</style>

@code {
    private List<OrderDto> orders = [];
    private OrdersSummaryDto? _summary;
    private string statusFilter = "";
    private string searchTerm = "";
    private string? cursor;
    private bool hasMore;
    private bool isLoadingMore;
    private bool _statsOpen = true;
    private bool _filtersOpen = true;

    private async Task ExportCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Order #,Status,Total,Currency,Created,Shipped,Delivered");
        foreach (var o in orders)
            sb.AppendLine($"\"{o.OrderNumber}\",\"{o.Status}\",{o.TotalAmount},\"{o.Currency}\",\"{o.CreatedAt:yyyy-MM-dd}\",\"{o.ShippedAt?.ToString("yyyy-MM-dd") ?? ""}\",\"{o.DeliveredAt?.ToString("yyyy-MM-dd") ?? ""}\"");
        await JS.InvokeVoidAsync("downloadCsv", $"orders_{DateTime.Today:yyyyMMdd}.csv", sb.ToString());
    }

    protected override async Task OnInitializedAsync()
    {
        var summaryTask = Api.GetOrdersSummaryAsync();
        await LoadOrders();
        _summary = await summaryTask;
    }

    private async Task Search()
    {
        cursor = null;
        await LoadOrders();
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task OnFilterChanged()
    {
        await Search();
    }

    private async Task LoadOrders()
    {
        var result = await Api.GetOrdersAsync(
            string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
            string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
            20, cursor);

        if (cursor is null)
            orders = result?.Items ?? [];
        else
            orders.AddRange(result?.Items ?? []);

        cursor = result?.NextCursor;
        hasMore = result?.HasMore ?? false;
    }

    private async Task LoadMore()
    {
        if (isLoadingMore || !hasMore) return;
        isLoadingMore = true;
        try
        {
            var result = await Api.GetOrdersAsync(
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
                20, cursor);

            orders.AddRange(result?.Items ?? []);
            cursor = result?.NextCursor;
            hasMore = result?.HasMore ?? false;
        }
        finally
        {
            isLoadingMore = false;
        }
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "Delivered"  => "badge-soft-success",
        "Cancelled"  => "badge-soft-danger",
        "Shipped"    => "badge-soft-info",
        "Confirmed"  => "badge-soft-primary",
        "Processing" => "badge-soft-purple",
        "Pending"    => "badge-soft-warning",
        _            => "badge-soft-neutral",
    };

    private static string FormatAmount(decimal value, string currency)
    {
        var sym = currency switch
        {
            "PHP" => "₱", "USD" => "$", "EUR" => "€", "GBP" => "£", _ => currency + " "
        };
        return value >= 1_000_000 ? $"{sym}{value / 1_000_000:N1}M"
             : value >= 1_000     ? $"{sym}{value / 1_000:N1}K"
             : $"{sym}{value:N0}";
    }

}