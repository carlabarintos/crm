@page "/orders/{Id:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>@(order?.OrderNumber ?? "Order")</PageTitle>

@if (order is null && error is null)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (order is not null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/orders">Orders</a></li>
            <li class="breadcrumb-item active">@order.OrderNumber</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Order info -->
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@order.OrderNumber</h5>
                    <span class="badge @GetStatusBadge(order.Status) fs-6">@order.Status</span>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Quote</dt>
                        <dd class="col-sm-8"><a href="/quotes/@order.QuoteId">@order.QuoteId.ToString()[..8]…</a></dd>

                        <dt class="col-sm-4">Net Total</dt>
                        <dd class="col-sm-8">@order.TotalAmount.ToString("F2") @order.Currency</dd>

                        @if (order.TaxRatePercent > 0)
                        {
                            <dt class="col-sm-4">@order.TaxRateName (@order.TaxRatePercent.ToString("0.##")%)</dt>
                            <dd class="col-sm-8 text-muted">+@order.TaxAmount.ToString("F2") @order.Currency</dd>
                        }

                        <dt class="col-sm-4">Grand Total</dt>
                        <dd class="col-sm-8 fw-bold text-primary fs-5">@order.GrandTotal.ToString("F2") @order.Currency</dd>

                        <dt class="col-sm-4">Shipping Address</dt>
                        <dd class="col-sm-8">@(order.ShippingAddress ?? "-")</dd>

                        <dt class="col-sm-4">Notes</dt>
                        <dd class="col-sm-8">@(order.Notes ?? "-")</dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8">@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                        @if (order.ShippedAt.HasValue)
                        {
                            <dt class="col-sm-4">Shipped</dt>
                            <dd class="col-sm-8">@order.ShippedAt.Value.ToString("MMM dd, yyyy HH:mm")</dd>
                        }
                        @if (order.DeliveredAt.HasValue)
                        {
                            <dt class="col-sm-4">Delivered</dt>
                            <dd class="col-sm-8">@order.DeliveredAt.Value.ToString("MMM dd, yyyy HH:mm")</dd>
                        }
                    </dl>
                </div>
            </div>

            <!-- Line items -->
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Line Items</h6></div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Line Total</th>
                                @if (order.Status == "Pending") { <th></th> }
                            </tr>
                        </thead>
                        <tbody>
                            @if (!order.LineItems.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3">No line items on this order.</td></tr>
                            }
                            @foreach (var l in order.LineItems)
                            {
                                @if (editingLineItemId == l.Id)
                                {
                                    <tr class="table-warning">
                                        <td>@l.ProductName</td>
                                        <td class="text-end" style="width:90px">
                                            <input class="form-control form-control-sm text-end" type="number" min="1" @bind="editQty" />
                                        </td>
                                        <td class="text-end" style="width:110px">
                                            <input class="form-control form-control-sm text-end" type="number" step="0.01" @bind="editUnitPrice" />
                                        </td>
                                        <td class="text-end fw-semibold">@((editQty * editUnitPrice).ToString("F2"))</td>
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-success btn-sm py-0 px-1 me-1" @onclick="() => SaveEdit(l.Id)" disabled="@lineItemSaving">✓</button>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="CancelEdit">✕</button>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td>@l.ProductName</td>
                                        <td class="text-end">@l.Quantity</td>
                                        <td class="text-end">@l.UnitPrice.ToString("F2")</td>
                                        <td class="text-end fw-semibold">@l.LineTotal.ToString("F2")</td>
                                        @if (order.Status == "Pending")
                                        {
                                            <td class="text-end text-nowrap">
                                                <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1" @onclick="() => StartEdit(l)">✎</button>
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => RemoveLineItem(l.Id)" disabled="@lineItemSaving">✕</button>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                            @if (order.Status == "Pending")
                            {
                                @if (showAddLineItem)
                                {
                                    <tr class="table-light">
                                        <td style="min-width:220px">
                                            <ProductCombobox Value="_newProduct" ValueChanged="OnAddProductSelected" />
                                            @if (addStockWarning is not null)
                                            {
                                                <div class="small @(addStockWarning.StartsWith("⚠") ? "text-warning" : "text-danger")">@addStockWarning</div>
                                            }
                                        </td>
                                        <td style="width:80px"><input class="form-control form-control-sm text-end" type="number" min="1" @bind="newQty" @bind:after="CheckAddStock" /></td>
                                        <td style="width:100px"><input class="form-control form-control-sm text-end" type="number" step="0.01" @bind="newUnitPrice" /></td>
                                        <td class="text-end fw-semibold text-muted">@((newQty * newUnitPrice).ToString("F2"))</td>
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-success btn-sm py-0 px-1 me-1" @onclick="AddLineItem" disabled="@lineItemSaving">✓</button>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="CancelAdd">✕</button>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5">
                                            <button class="btn btn-link btn-sm p-0" @onclick="() => showAddLineItem = true">+ Add line item</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="@(order.Status == "Pending" ? 3 : 3)" class="text-end">Total</td>
                                <td class="text-end text-primary">@order.TotalAmount.ToString("F2") @order.Currency</td>
                                @if (order.Status == "Pending") { <td></td> }
                            </tr>
                        </tfoot>
                    </table>
                </div>
                @if (!string.IsNullOrEmpty(lineItemError))
                {
                    <div class="card-footer text-danger small">@lineItemError</div>
                }
            </div>
        </div>

        <!-- Actions sidebar -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0">Order Actions</h6></div>
                <div class="card-body d-grid gap-2">
                    @if (order.Status == "Pending")
                    {
                        <button class="btn btn-primary btn-sm" @onclick="Confirm" disabled="@actionSaving">Confirm Order</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => showCancelForm = !showCancelForm">Cancel Order</button>
                    }
                    @if (order.Status == "Confirmed")
                    {
                        <button class="btn btn-warning btn-sm" @onclick="Process" disabled="@actionSaving">Start Processing</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => showCancelForm = !showCancelForm">Cancel Order</button>
                    }
                    @if (order.Status == "Processing")
                    {
                        <button class="btn btn-info btn-sm" @onclick="() => showShipForm = !showShipForm">Ship Order</button>
                    }
                    @if (order.Status == "Shipped")
                    {
                        <button class="btn btn-success btn-sm" @onclick="Deliver" disabled="@actionSaving">Mark Delivered</button>
                    }

                    @if (showShipForm)
                    {
                        <div class="mt-2">
                            <input class="form-control form-control-sm mb-1" @bind="trackingInfo" placeholder="Tracking number (optional)" />
                            <button class="btn btn-sm btn-info w-100" @onclick="Ship" disabled="@actionSaving">Confirm Ship</button>
                        </div>
                    }
                    @if (showCancelForm)
                    {
                        <div class="mt-2">
                            <input class="form-control form-control-sm mb-1" @bind="cancelReason" placeholder="Reason for cancellation" />
                            <button class="btn btn-sm btn-danger w-100" @onclick="Cancel" disabled="@actionSaving">Confirm Cancel</button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(actionError)) { <div class="text-danger small">@actionError</div> }
                    @if (!string.IsNullOrEmpty(actionSuccess)) { <div class="text-success small">@actionSuccess</div> }

                    <a href="/orders" class="btn btn-outline-secondary btn-sm mt-2">Back to List</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private OrderDetailDto? order;
    private string? error;
    private bool actionSaving;
    private string? actionError;
    private string? actionSuccess;

    private bool showShipForm;
    private string? trackingInfo;
    private bool showCancelForm;
    private string cancelReason = "";

    // Line item management
    private bool lineItemSaving;
    private string? lineItemError;

    private bool showAddLineItem;
    private ProductDto? _newProduct;
    private int newQty = 1;
    private decimal newUnitPrice;
    private string? addStockWarning;

    private Guid? editingLineItemId;
    private int editQty;
    private decimal editUnitPrice;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { order = await Api.GetOrderAsync(Id); }
        catch { error = "Failed to load order."; }
    }

    private async Task Confirm()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.ConfirmOrderAsync(Id);
            if (resp.IsSuccessStatusCode) { actionSuccess = "Order confirmed."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Process()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.ProcessOrderAsync(Id);
            if (resp.IsSuccessStatusCode) { actionSuccess = "Order is now processing."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Ship()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.ShipOrderAsync(Id, trackingInfo);
            if (resp.IsSuccessStatusCode) { showShipForm = false; actionSuccess = "Order shipped."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Deliver()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.DeliverOrderAsync(Id);
            if (resp.IsSuccessStatusCode) { actionSuccess = "Order marked as delivered."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Cancel()
    {
        actionError = null; actionSuccess = null;
        if (string.IsNullOrWhiteSpace(cancelReason)) { actionError = "Cancellation reason is required."; return; }
        actionSaving = true;
        try
        {
            var resp = await Api.CancelOrderAsync(Id, cancelReason);
            if (resp.IsSuccessStatusCode) { showCancelForm = false; actionSuccess = "Order cancelled."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private void StartEdit(OrderLineItemDto l)
    {
        editingLineItemId = l.Id;
        editQty = l.Quantity;
        editUnitPrice = l.UnitPrice;
    }

    private void CancelEdit() => editingLineItemId = null;

    private async Task SaveEdit(Guid lineItemId)
    {
        lineItemError = null; lineItemSaving = true;
        try
        {
            var resp = await Api.UpdateOrderLineItemAsync(Id, lineItemId, new { Quantity = editQty, UnitPrice = editUnitPrice });
            if (resp.IsSuccessStatusCode) { editingLineItemId = null; await Load(); }
            else lineItemError = await resp.Content.ReadAsStringAsync();
        }
        finally { lineItemSaving = false; }
    }

    private void OnAddProductSelected(ProductDto? p)
    {
        _newProduct = p;
        newUnitPrice = p?.Price ?? 0;
        addStockWarning = null;
        CheckAddStock();
    }

    private void CheckAddStock()
    {
        addStockWarning = null;
        if (_newProduct is null) return;
        if (_newProduct.StockQuantity == 0) addStockWarning = "⚠ Out of stock";
        else if (newQty > _newProduct.StockQuantity) addStockWarning = $"⚠ Only {_newProduct.StockQuantity} in stock";
    }

    private void CancelAdd()
    {
        showAddLineItem = false;
        _newProduct = null; newQty = 1; newUnitPrice = 0; addStockWarning = null;
    }

    private async Task AddLineItem()
    {
        lineItemError = null;
        if (_newProduct is null) { lineItemError = "Please select a product."; return; }
        if (newQty <= 0) { lineItemError = "Quantity must be positive."; return; }
        lineItemSaving = true;
        try
        {
            var resp = await Api.AddOrderLineItemAsync(Id, new
            {
                ProductId = _newProduct.Id,
                ProductName = _newProduct.Name,
                Quantity = newQty,
                UnitPrice = newUnitPrice
            });
            if (resp.IsSuccessStatusCode)
            {
                CancelAdd();
                await Load();
            }
            else lineItemError = await resp.Content.ReadAsStringAsync();
        }
        finally { lineItemSaving = false; }
    }

    private async Task RemoveLineItem(Guid lineItemId)
    {
        lineItemError = null; lineItemSaving = true;
        try
        {
            var resp = await Api.DeleteOrderLineItemAsync(Id, lineItemId);
            if (resp.IsSuccessStatusCode) await Load();
            else lineItemError = await resp.Content.ReadAsStringAsync();
        }
        finally { lineItemSaving = false; }
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        "Shipped" => "bg-info text-dark",
        "Confirmed" => "bg-primary",
        "Processing" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
