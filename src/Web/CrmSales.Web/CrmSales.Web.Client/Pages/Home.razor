@code {
    private static readonly (string Stage, string Color, string Label)[] PipelineStages =
    [
        ("Prospecting",   "linear-gradient(90deg,#6366f1,#818cf8)", "Top of Funnel"),
        ("Qualification", "linear-gradient(90deg,#8b5cf6,#a78bfa)", "Qualifying"),
        ("Proposal",      "linear-gradient(90deg,#06b6d4,#22d3ee)", "Proposal"),
        ("ClosedWon",     "linear-gradient(90deg,#10b981,#34d399)",  "Won"),
    ];

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool loading = true;
    private bool _kpiOpen = true;
    private bool _pipelineOpen = true;
    private bool _expiringOpen = true;
    private bool _activityOpen = true;
    private bool _stockOpen = true;

    private List<ProductDto> lowStockProducts = [];
    private List<ExpiringOpportunityDto> expiringOpportunities = [];
    private List<ExpiringQuoteDto> expiringQuotes = [];
    private List<AuditLogDto> recentActivity = [];

    private decimal pipelineValue;
    private string pipelineCurrency = "PHP";
    private int openOppCount;
    private int wonCount;
    private int lostCount;
    private decimal forecast;
    private decimal winRate;
    private double avgDaysToClose;
    private int activeQuoteCount;
    private int totalQuoteCount;
    private int activeOrderCount;
    private int totalOrderCount;
    private int activeProductCount;
    private Dictionary<string, (int Count, decimal Value)> stageCounts = new();
    private decimal maxStageValue = 1;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateTask;
        var user = auth.User;

        if (user.IsInRole("SuperAdmin"))
        {
            Navigation.NavigateTo("/companies", replace: true);
            return;
        }

        var oppSummaryTask      = Api.GetOpportunitySummaryAsync();
        var quoteSummaryTask    = Api.GetQuotesSummaryAsync();
        var orderSummaryTask    = Api.GetOrdersSummaryAsync();
        var prodSummaryTask     = Api.GetProductSummaryAsync();
        var activityTask        = Api.GetAuditLogsAsync(page: 1, pageSize: 8);
        var expiringOppTask     = Api.GetExpiringOpportunitiesAsync();
        var expiringQuoteTask   = Api.GetExpiringQuotesAsync();
        var lowStockTask        = Api.GetProductsAsync(lowInventory: true, limit: 8);

        var oppSummary        = await oppSummaryTask;
        var quoteSummary      = await quoteSummaryTask;
        var orderSummary      = await orderSummaryTask;
        var prodSummary       = await prodSummaryTask;
        recentActivity        = (await activityTask)?.Items ?? [];
        expiringOpportunities = (await expiringOppTask) ?? [];
        expiringQuotes        = (await expiringQuoteTask) ?? [];
        lowStockProducts      = (await lowStockTask)?.Items ?? [];

        if (oppSummary is not null)
        {
            openOppCount   = oppSummary.OpenCount;
            pipelineValue  = oppSummary.PipelineValue;
            forecast       = oppSummary.WeightedValue;
            wonCount       = oppSummary.WonCount;
            lostCount      = oppSummary.LostCount;
            winRate        = decimal.TryParse(oppSummary.WinRate.TrimEnd('%'), out var wr) ? wr : 0;
            avgDaysToClose = oppSummary.AvgDaysToClose;
            pipelineCurrency = oppSummary.Currency;

            stageCounts = oppSummary.ByStage.ToDictionary(
                s => s.Stage, s => (s.Count, s.Value));
        }

        maxStageValue = PipelineStages
            .Select(p => stageCounts.TryGetValue(p.Stage, out var v) ? v.Value : 0m)
            .DefaultIfEmpty(1m).Max();
        if (maxStageValue <= 0) maxStageValue = 1;

        totalQuoteCount  = quoteSummary?.TotalCount ?? 0;
        activeQuoteCount = (quoteSummary?.DraftCount ?? 0) + (quoteSummary?.SentCount ?? 0);
        totalOrderCount  = orderSummary?.TotalCount ?? 0;
        activeOrderCount = orderSummary?.ActiveCount ?? 0;
        activeProductCount = prodSummary?.ActiveCount ?? 0;

        loading = false;
    }

    private double GetBarWidth(string stage)
    {
        if (!stageCounts.TryGetValue(stage, out var data) || data.Count == 0) return 0;
        var pct = (double)(data.Value / maxStageValue * 85);
        return Math.Max(pct, 10);
    }

    private static string GetActDotClass(string eventType)
    {
        var lower = eventType.ToLowerInvariant();
        if (lower.Contains("creat") || lower.Contains("add")) return "act-dot-create";
        if (lower.Contains("delet") || lower.Contains("remov") || lower.Contains("cancel")) return "act-dot-delete";
        if (lower.Contains("status") || lower.Contains("sent") || lower.Contains("accept") || lower.Contains("reject") || lower.Contains("ship") || lower.Contains("deliver") || lower.Contains("expir")) return "act-dot-status";
        return "act-dot-update";
    }

    private static string FormatTimeAgo(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 2) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utc.ToString("MMM d");
    }

    private string FormatCurrency(decimal value)
    {
        var symbol = pipelineCurrency switch
        {
            "PHP" => "₱", "USD" => "$", "EUR" => "€", "GBP" => "£", "AUD" => "A$",
            _ => pipelineCurrency + " "
        };
        return value >= 1_000_000 ? $"{symbol}{value / 1_000_000:N1}M"
             : value >= 1_000     ? $"{symbol}{value / 1_000:N1}K"
             : $"{symbol}{value:N0}";
    }

    private static string GetUrgencyBadgeClass(int? daysLeft)
    {
        if (!daysLeft.HasValue) return "badge-soft-neutral";
        if (daysLeft.Value <= 3) return "badge-urgency-red";
        if (daysLeft.Value <= 7) return "badge-urgency-amber";
        return "badge-urgency-yellow";
    }

    private static string GetDaysLeftText(int? daysLeft)
    {
        if (!daysLeft.HasValue) return "—";
        if (daysLeft.Value <= 0) return "Expired";
        if (daysLeft.Value == 1) return "1 day left";
        return $"{daysLeft.Value} days left";
    }
}
