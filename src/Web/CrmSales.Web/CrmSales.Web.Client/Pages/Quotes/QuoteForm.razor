@page "/quotes/new"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>New Quote</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/quotes">Quotes</a></li>
        <li class="breadcrumb-item active">New</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Left: Quote details -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Quote Details</h5></div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Currency</label>
                        <select class="form-select" @bind="currency">
                            <option>PHP</option>
                            <option>USD</option>
                            <option>EUR</option>
                            <option>GBP</option>
                            <option>AUD</option>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Expiry Date</label>
                        <input class="form-control" type="date" @bind="expiryDate" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Owner <span class="text-danger">*</span></label>
                    @if (isSalesRep)
                    {
                        <input class="form-control" value="@(users?.FirstOrDefault(u => u.Id.ToString() == ownerIdRaw)?.FullName ?? "You")" disabled />
                    }
                    else if (users is null)
                    {
                        <div class="text-muted small">Loading users...</div>
                    }
                    else if (!users.Any())
                    {
                        <input class="form-control" @bind="ownerIdRaw" placeholder="No users yet — paste a User ID" />
                    }
                    else
                    {
                        <select class="form-select" @bind="ownerIdRaw">
                            <option value="">— Select owner —</option>
                            @foreach (var u in users)
                            {
                                <option value="@u.Id">@u.FullName (@u.Role)</option>
                            }
                        </select>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea class="form-control" @bind="notes" rows="3" placeholder="Optional notes"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Create Quote
                </button>
                <a href="/quotes" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>

    <!-- Right: Opportunity + Products -->
    <div class="col-md-7">

        <!-- Opportunity panel -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Opportunity <span class="text-danger">*</span></h6>
                @if (!creatingOpportunity)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => creatingOpportunity = true">+ New Opportunity</button>
                }
            </div>
            <div class="card-body">
                @if (!creatingOpportunity)
                {
                    <!-- Select existing opportunity -->
                    @if (opportunities is null)
                    {
                        <div class="text-muted small">Loading opportunities...</div>
                    }
                    else if (!opportunities.Any())
                    {
                        <p class="text-muted small mb-2">No opportunities yet. Click "+ New Opportunity" to create one.</p>
                    }
                    else
                    {
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Select existing opportunity</label>
                            <select class="form-select" @bind="opportunityIdRaw" @bind:after="OnOpportunitySelected">
                                <option value="">— Select opportunity —</option>
                                @foreach (var o in opportunities)
                                {
                                    <option value="@o.Id">@o.Name — @o.AccountName</option>
                                }
                            </select>
                        </div>
                        @if (selectedOpportunity is not null)
                        {
                            <div class="p-3 rounded" style="background:#F3F4F6">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">@selectedOpportunity.Name</div>
                                        <div class="text-muted small">@selectedOpportunity.AccountName</div>
                                        <div class="text-muted small">Contact: @selectedOpportunity.ContactName</div>
                                    </div>
                                    <span class="badge bg-light text-dark border">@selectedOpportunity.Stage</span>
                                </div>
                                <div class="mt-1 small text-primary fw-semibold">
                                    @selectedOpportunity.Currency @selectedOpportunity.EstimatedValue.ToString("N2")
                                </div>
                            </div>
                        }
                    }
                }
                else
                {
                    <!-- Inline create opportunity -->
                    <div class="mb-2">
                        <label class="form-label form-label-sm">Opportunity Name <span class="text-danger">*</span></label>
                        <input class="form-control form-control-sm" @bind="newOppName" placeholder="e.g. Website Redesign Project" />
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label form-label-sm">Account Name <span class="text-danger">*</span></label>
                            <input class="form-control form-control-sm" @bind="newOppAccount" placeholder="Company / Account" />
                        </div>
                        <div class="col">
                            <label class="form-label form-label-sm">Contact Name <span class="text-danger">*</span></label>
                            <input class="form-control form-control-sm" @bind="newOppContact" placeholder="Primary contact" />
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label form-label-sm">Estimated Value <span class="text-danger">*</span></label>
                            <input class="form-control form-control-sm" type="number" step="0.01" @bind="newOppValue" />
                        </div>
                        <div class="col">
                            <label class="form-label form-label-sm">Currency</label>
                            <select class="form-select form-select-sm" @bind="newOppCurrency">
                                <option>PHP</option>
                                <option>USD</option>
                                <option>EUR</option>
                                <option>GBP</option>
                                <option>AUD</option>
                            </select>
                        </div>
                        <div class="col">
                            <label class="form-label form-label-sm">Close Date</label>
                            <input class="form-control form-control-sm" type="date" @bind="newOppCloseDate" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm">Owner <span class="text-danger">*</span></label>
                        @if (isSalesRep)
                        {
                            <input class="form-control form-control-sm" value="@(users?.FirstOrDefault(u => u.Id.ToString() == newOppOwnerIdRaw)?.FullName ?? "You")" disabled />
                        }
                        else if (users is null || !users.Any())
                        {
                            <input class="form-control form-control-sm" @bind="newOppOwnerIdRaw" placeholder="Paste a User ID" />
                        }
                        else
                        {
                            <select class="form-select form-select-sm" @bind="newOppOwnerIdRaw">
                                <option value="">— Select owner —</option>
                                @foreach (var u in users)
                                {
                                    <option value="@u.Id">@u.FullName (@u.Role)</option>
                                }
                            </select>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(oppCreateError))
                    {
                        <div class="text-danger small mb-1">@oppCreateError</div>
                    }
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="CreateOpportunity" disabled="@creatingOppSaving">
                            @if (creatingOppSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save Opportunity
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => { creatingOpportunity = false; oppCreateError = null; }">Cancel</button>
                    </div>
                }
            </div>
        </div>

        <!-- Products / Line Items -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Products</h6>
                <span class="text-muted small">Optional — can also be added after creating</span>
            </div>
            <div class="card-body">
                <!-- Add product row -->
                <div class="row g-2 mb-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label form-label-sm">Product</label>
                        <select class="form-select form-select-sm" @bind="newItemProductId" @bind:after="OnProductSelected">
                            <option value="">— Select product —</option>
                            @foreach (var p in products ?? [])
                            {
                                <option value="@p.Id">
                                    @p.Name — @(p.StockQuantity > 0 ? $"{p.StockQuantity} in stock" : "Out of stock")
                                </option>
                            }
                        </select>
                        @if (selectedProduct is not null)
                        {
                            <div class="mt-1 small @StockClass(selectedProduct.StockQuantity)">
                                @if (selectedProduct.StockQuantity == 0)
                                { <span>⚠ Out of stock</span> }
                                else if (selectedProduct.StockQuantity <= LowStockThreshold)
                                { <span>⚠ Low stock: @selectedProduct.StockQuantity units available</span> }
                                else
                                { <span>✓ @selectedProduct.StockQuantity units available</span> }
                            </div>
                        }
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Qty</label>
                        <input type="number" class="form-control form-control-sm" @bind="newItemQty" min="1" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Unit Price</label>
                        <input type="number" class="form-control form-control-sm" @bind="newItemUnitPrice" step="0.01" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Disc %</label>
                        <input type="number" class="form-control form-control-sm" @bind="newItemDiscount" min="0" max="100" />
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-sm btn-outline-primary w-100" @onclick="AddLineItemDraft" title="Add">+</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(lineItemWarning))
                {
                    <div class="text-warning small mb-1">⚠ @lineItemWarning</div>
                }
                @if (!string.IsNullOrEmpty(lineItemError))
                {
                    <div class="text-danger small mb-2">@lineItemError</div>
                }

                @if (lineItems.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Disc %</th>
                                <th class="text-end">Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, idx) in lineItems.Select((x, i) => (x, i)))
                            {
                                var lineTotal = item.Quantity * item.UnitPrice * (1 - item.DiscountPercent / 100m);
                                <tr>
                                    <td style="font-size:13px">@item.ProductName</td>
                                    <td class="text-end" style="font-size:13px">@item.Quantity</td>
                                    <td class="text-end" style="font-size:13px">@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end" style="font-size:13px">@item.DiscountPercent%</td>
                                    <td class="text-end fw-semibold" style="font-size:13px">@lineTotal.ToString("N2")</td>
                                    <td class="text-end">
                                        <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => lineItems.RemoveAt(idx)">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td colspan="4" class="text-end fw-semibold" style="font-size:13px">Total:</td>
                                <td class="text-end fw-bold" style="font-size:13px">
                                    @lineItems.Sum(i => i.Quantity * i.UnitPrice * (1 - i.DiscountPercent / 100m)).ToString("N2")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3" style="font-size:13px">No products added yet.</div>
                }
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "opportunityId")]
    public Guid? OpportunityId { get; set; }

    // Quote fields
    private string opportunityIdRaw = "";
    private string ownerIdRaw = "";
    private string currency = "PHP";
    private DateTime? expiryDate = DateTime.Today.AddDays(2);
    private string? notes;

    private OpportunityDto? selectedOpportunity;
    private List<OpportunityDto>? opportunities;
    private List<UserDto>? users;
    private List<ProductDto>? products;
    private bool isSalesRep;
    private bool saving;
    private string? error;

    // Inline opportunity creation
    private bool creatingOpportunity;
    private bool creatingOppSaving;
    private string? oppCreateError;
    private string newOppName = "", newOppAccount = "", newOppContact = "";
    private decimal newOppValue;
    private string newOppCurrency = "PHP";
    private DateTime? newOppCloseDate;
    private string newOppOwnerIdRaw = "";

    // Line items
    private List<LineItemDraft> lineItems = new();
    private string newItemProductId = "";
    private int newItemQty = 1;
    private decimal newItemUnitPrice;
    private decimal newItemDiscount;
    private string? lineItemError;

    private record LineItemDraft(Guid ProductId, string ProductName, int Quantity, decimal UnitPrice, decimal DiscountPercent);
    private record QuoteCreatedResult(Guid Id, string QuoteNumber);

    protected override async Task OnInitializedAsync()
    {
        var oppTask = Api.GetOpportunitiesAsync();
        var prodTask = Api.GetProductsAsync(isActive: true);
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();

        isSalesRep = auth.User.IsInRole("SalesRep");
        var currentEmail = auth.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? auth.User.FindFirst("email")?.Value;

        opportunities = await oppTask;
        products = await prodTask;

        if (OpportunityId.HasValue)
        {
            opportunityIdRaw = OpportunityId.Value.ToString();
            selectedOpportunity = opportunities?.FirstOrDefault(o => o.Id == OpportunityId.Value);
        }
        else if (opportunities?.Count == 1)
        {
            opportunityIdRaw = opportunities[0].Id.ToString();
            selectedOpportunity = opportunities[0];
        }

        if (isSalesRep)
        {
            ownerIdRaw = auth.User.FindFirst("sub")?.Value
                ?? auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                ?? "";
            newOppOwnerIdRaw = ownerIdRaw;
        }
        else
        {
            users = await Api.GetUsersAsync();
            var match = users?.FirstOrDefault(u =>
                string.Equals(u.Email, currentEmail, StringComparison.OrdinalIgnoreCase));

            if (match is not null)
            {
                ownerIdRaw = match.Id.ToString();
                newOppOwnerIdRaw = match.Id.ToString();
            }
            else if (users?.Count == 1)
            {
                ownerIdRaw = users[0].Id.ToString();
                newOppOwnerIdRaw = users[0].Id.ToString();
            }
        }
    }

    private const int LowStockThreshold = 10;
    private ProductDto? selectedProduct;
    private string? lineItemWarning;

    private static string StockClass(int stock) =>
        stock == 0 ? "text-danger" : stock <= LowStockThreshold ? "text-warning" : "text-success";

    private void OnProductSelected()
    {
        lineItemWarning = null;
        if (Guid.TryParse(newItemProductId, out var pid))
        {
            selectedProduct = products?.FirstOrDefault(p => p.Id == pid);
            if (selectedProduct is not null)
                newItemUnitPrice = selectedProduct.Price;
        }
        else
        {
            selectedProduct = null;
            newItemUnitPrice = 0;
        }
    }

    private void AddLineItemDraft()
    {
        lineItemError = null;
        lineItemWarning = null;
        if (!Guid.TryParse(newItemProductId, out var pid)) { lineItemError = "Please select a product."; return; }
        if (newItemQty <= 0) { lineItemError = "Quantity must be at least 1."; return; }
        if (newItemUnitPrice < 0) { lineItemError = "Unit price cannot be negative."; return; }

        var product = products?.FirstOrDefault(p => p.Id == pid);
        if (product is null) { lineItemError = "Product not found."; return; }

        if (product.StockQuantity == 0)
            lineItemWarning = $"{product.Name} is currently out of stock.";
        else if (newItemQty > product.StockQuantity)
            lineItemWarning = $"Only {product.StockQuantity} units of {product.Name} available — quoting {newItemQty}.";

        var existing = lineItems.FirstOrDefault(l => l.ProductId == pid);
        if (existing is not null)
        {
            var idx = lineItems.IndexOf(existing);
            lineItems[idx] = existing with { Quantity = existing.Quantity + newItemQty };
        }
        else
        {
            lineItems.Add(new LineItemDraft(pid, product.Name, newItemQty, newItemUnitPrice, newItemDiscount));
        }

        selectedProduct = null;
        newItemProductId = "";
        newItemQty = 1;
        newItemUnitPrice = 0;
        newItemDiscount = 0;
    }

    private void OnOpportunitySelected()
    {
        if (Guid.TryParse(opportunityIdRaw, out var oid))
            selectedOpportunity = opportunities?.FirstOrDefault(o => o.Id == oid);
        else
            selectedOpportunity = null;
    }

    private async Task CreateOpportunity()
    {
        oppCreateError = null;
        if (string.IsNullOrWhiteSpace(newOppName)) { oppCreateError = "Opportunity name is required."; return; }
        if (string.IsNullOrWhiteSpace(newOppAccount)) { oppCreateError = "Account name is required."; return; }
        if (string.IsNullOrWhiteSpace(newOppContact)) { oppCreateError = "Contact name is required."; return; }
        if (newOppValue <= 0) { oppCreateError = "Estimated value must be greater than 0."; return; }
        if (!Guid.TryParse(newOppOwnerIdRaw, out var ownerGuid)) { oppCreateError = "Please select an owner."; return; }

        creatingOppSaving = true;
        try
        {
            var resp = await Api.CreateOpportunityAsync(new
            {
                Name = newOppName,
                AccountName = newOppAccount,
                ContactName = newOppContact,
                ContactEmail = (string?)null,
                ContactPhone = (string?)null,
                EstimatedValue = newOppValue,
                Currency = newOppCurrency,
                ExpectedCloseDate = newOppCloseDate,
                Description = (string?)null,
                OwnerId = ownerGuid
            });

            if (resp.IsSuccessStatusCode)
            {
                opportunities = await Api.GetOpportunitiesAsync();
                var created = opportunities?.FirstOrDefault(o =>
                    o.Name == newOppName && o.AccountName == newOppAccount);
                if (created != null)
                {
                    opportunityIdRaw = created.Id.ToString();
                    selectedOpportunity = created;
                }
                creatingOpportunity = false;
                newOppName = ""; newOppAccount = ""; newOppContact = "";
                newOppValue = 0; newOppCloseDate = null;
            }
            else
            {
                oppCreateError = await resp.Content.ReadAsStringAsync();
            }
        }
        finally { creatingOppSaving = false; }
    }

    private async Task Save()
    {
        error = null;
        if (!Guid.TryParse(opportunityIdRaw, out var oppId)) { error = "Please select or create an opportunity."; return; }
        if (!Guid.TryParse(ownerIdRaw, out var ownerGuid)) { error = "Please select an owner."; return; }

        saving = true;
        try
        {
            var resp = await Api.CreateQuoteAsync(new
            {
                OpportunityId = oppId,
                OwnerId = ownerGuid,
                Currency = currency,
                ExpiryDate = expiryDate,
                Notes = notes
            });

            if (resp.IsSuccessStatusCode)
            {
                var created = await resp.Content.ReadFromJsonAsync<QuoteCreatedResult>();
                if (created is not null && lineItems.Any())
                {
                    foreach (var item in lineItems)
                    {
                        await Api.AddLineItemAsync(created.Id, new
                        {
                            ProductId = item.ProductId,
                            ProductName = item.ProductName,
                            Quantity = item.Quantity,
                            UnitPrice = item.UnitPrice,
                            DiscountPercent = item.DiscountPercent
                        });
                    }
                }
                Nav.NavigateTo(created is not null ? $"/quotes/{created.Id}" : "/quotes");
            }
            else
                error = await resp.Content.ReadAsStringAsync();
        }
        finally { saving = false; }
    }
}
