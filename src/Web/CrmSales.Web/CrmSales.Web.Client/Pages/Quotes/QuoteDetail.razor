@page "/quotes/{Id:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(quote?.QuoteNumber ?? "Quote")</PageTitle>

@if (quote is null && error is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (quote is not null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/quotes">Quotes</a></li>
            <li class="breadcrumb-item active">@quote.QuoteNumber</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Left: quote info + line items -->
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@quote.QuoteNumber</h5>
                    <span class="badge @GetStatusBadge(quote.Status) fs-6">@quote.Status</span>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Opportunity</dt>
                        <dd class="col-sm-8"><a href="/opportunities/@quote.OpportunityId">View Opportunity</a></dd>
                        <dt class="col-sm-4">Currency</dt>
                        <dd class="col-sm-8">@quote.Currency</dd>
                        <dt class="col-sm-4">Expiry Date</dt>
                        <dd class="col-sm-8">@(quote.ExpiryDate?.ToString("MMM dd, yyyy") ?? "-")</dd>
                        <dt class="col-sm-4">Notes</dt>
                        <dd class="col-sm-8">@(quote.Notes ?? "-")</dd>
                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8">@quote.CreatedAt.ToString("MMM dd, yyyy")</dd>
                    </dl>
                </div>
            </div>

            <!-- Line Items -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Products / Line Items</h6>
                    @if (quote.Status == "Draft")
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="ToggleAddItem">
                            @(showLineItemForm ? "Cancel" : "+ Add Product")
                        </button>
                    }
                </div>

                @if (showLineItemForm && quote.Status == "Draft")
                {
                    <div class="card-body border-bottom">
                        <div class="row g-2 mb-2">
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Product</label>
                                <ProductCombobox Value="_liProduct" ValueChanged="OnProductSelected" />
                            </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Qty</label>
                                    <input class="form-control form-control-sm" type="number" min="1" @bind="liQuantity" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Unit Price</label>
                                    <input class="form-control form-control-sm" type="number" step="0.01" @bind="liUnitPrice" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Discount %</label>
                                    <input class="form-control form-control-sm" type="number" step="0.01" min="0" max="100" @bind="liDiscount" />
                                </div>
                            </div>
                            @if (liUnitPrice > 0 && liQuantity > 0)
                            {
                                var lineTotal = liUnitPrice * liQuantity * (1 - liDiscount / 100);
                                <div class="text-muted small mb-2">Line total: @quote.Currency @lineTotal.ToString("F2")</div>
                            }
                            @if (!string.IsNullOrEmpty(liError)) { <div class="text-danger small mb-1">@liError</div> }
                            <button class="btn btn-sm btn-primary" @onclick="AddLineItem" disabled="@(liSaving || _liProduct is null)">
                                @if (liSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Add to Quote
                            </button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Discount</th>
                                <th class="text-end">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!quote.LineItems.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3">No products added yet.</td></tr>
                            }
                            @foreach (var l in quote.LineItems)
                            {
                                <tr>
                                    <td>@l.ProductName</td>
                                    <td class="text-end">@l.Quantity</td>
                                    <td class="text-end">@l.UnitPrice.ToString("F2")</td>
                                    <td class="text-end">@(l.DiscountPercent > 0 ? $"{l.DiscountPercent}%" : "-")</td>
                                    <td class="text-end fw-semibold">@l.LineTotal.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                        @if (quote.LineItems.Any())
                        {
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="4" class="text-end text-muted">Subtotal</td>
                                    <td class="text-end">@quote.SubTotal.ToString("F2")</td>
                                </tr>
                                @if (quote.DiscountTotal > 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-end text-muted">Discount</td>
                                        <td class="text-end text-muted">-@quote.DiscountTotal.ToString("F2")</td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="4" class="text-end text-muted">Net Total</td>
                                    <td class="text-end">@quote.TotalAmount.ToString("F2")</td>
                                </tr>
                                @if (quote.TaxRatePercent > 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-end text-muted">
                                            @quote.TaxRateName (@quote.TaxRatePercent.ToString("0.##")%)
                                            @if (quote.Status == "Draft")
                                            {
                                                <button class="btn btn-link btn-sm text-danger p-0 ms-2"
                                                        style="font-size:11px;vertical-align:baseline"
                                                        @onclick="RemoveTax" disabled="@_taxRemoving">Remove</button>
                                            }
                                        </td>
                                        <td class="text-end text-muted">+@quote.TaxAmount.ToString("F2")</td>
                                    </tr>
                                }
                                <tr class="fw-bold">
                                    <td colspan="4" class="text-end">Grand Total</td>
                                    <td class="text-end text-primary">@quote.GrandTotal.ToString("F2") @quote.Currency</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: Actions -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0">Actions</h6></div>
                <div class="card-body d-grid gap-2">
                    @if (quote.Status == "Draft")
                    {
                        <button class="btn btn-info btn-sm" @onclick="Send" disabled="@actionSaving">
                            Send to Customer
                        </button>
                    }
                    @if (quote.Status == "Sent")
                    {
                        <button class="btn btn-success btn-sm" @onclick="Accept" disabled="@actionSaving">
                            ✓ Accept Quote &amp; Create Order
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => showRejectForm = !showRejectForm">
                            Reject Quote
                        </button>
                    }
                    @if (quote.Status == "Accepted")
                    {
                        <div class="alert alert-success py-2 mb-0 small">
                            Quote accepted. <a href="@(order != null ? $"/orders/{order.Id}" : "/orders")">View Order</a>
                        </div>
                    }

                    @if (showRejectForm)
                    {
                        <div>
                            <input class="form-control form-control-sm mb-1" @bind="rejectReason" placeholder="Reason (optional)" />
                            <button class="btn btn-sm btn-danger w-100" @onclick="Reject" disabled="@actionSaving">Confirm Reject</button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(actionError)) { <div class="text-danger small">@actionError</div> }
                    @if (!string.IsNullOrEmpty(actionSuccess)) { <div class="text-success small">@actionSuccess</div> }

                    <button class="btn btn-outline-secondary btn-sm" @onclick="PrintQuote">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-right:4px;vertical-align:-1px">
                            <rect x="2" y="5" width="10" height="7" rx="1"/><path d="M4 5V2h6v3" stroke-linecap="round"/>
                            <path d="M4 9h6M4 11h4" stroke-linecap="round"/>
                        </svg>
                        Print Quote
                    </button>
                    <a href="/quotes" class="btn btn-outline-secondary btn-sm">Back to Quotes</a>
                </div>
            </div>

            <!-- Totals summary card -->
            @if (quote.LineItems.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted small">Items</span>
                            <span class="small">@quote.LineItems.Count</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted small">Net Total</span>
                            <span class="small">@quote.TotalAmount.ToString("F2") @quote.Currency</span>
                        </div>
                        @if (quote.TaxRatePercent > 0)
                        {
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">@quote.TaxRateName (@quote.TaxRatePercent.ToString("0.##")%)</span>
                                <span class="small text-muted">+@quote.TaxAmount.ToString("F2")</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between fw-bold border-top pt-1 mt-1">
                            <span>Grand Total</span>
                            <span class="text-primary">@quote.GrandTotal.ToString("F2") @quote.Currency</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Print layout: hidden on screen, shown during browser print -->
@if (quote is not null)
{
    <div class="qprint-layout">
        <div class="qprint-header">
            <div>
                <div class="qprint-company">CRM Sales</div>
                <div class="qprint-sub">Sales Quotation</div>
            </div>
            <div class="text-end">
                <div class="qprint-num">@quote.QuoteNumber</div>
                <div class="qprint-meta">Created: @quote.CreatedAt.ToString("MMM dd, yyyy")</div>
                @if (quote.ExpiryDate.HasValue)
                {
                    <div class="qprint-meta">Expires: @quote.ExpiryDate.Value.ToString("MMM dd, yyyy")</div>
                }
                <div class="qprint-meta">Status: @quote.Status</div>
            </div>
        </div>

        <table class="qprint-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th class="text-end">Qty</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-end">Discount</th>
                    <th class="text-end">Line Total</th>
                </tr>
            </thead>
            <tbody>
                @if (!quote.LineItems.Any())
                {
                    <tr><td colspan="5" style="text-align:center;color:#6B7280">No line items.</td></tr>
                }
                @foreach (var l in quote.LineItems)
                {
                    <tr>
                        <td>@l.ProductName</td>
                        <td class="text-end">@l.Quantity</td>
                        <td class="text-end">@l.UnitPrice.ToString("F2")</td>
                        <td class="text-end">@(l.DiscountPercent > 0 ? $"{l.DiscountPercent}%" : "—")</td>
                        <td class="text-end">@l.LineTotal.ToString("F2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @if (quote.DiscountTotal > 0)
                {
                    <tr>
                        <td colspan="4" class="text-end" style="color:#6B7280">Discount</td>
                        <td class="text-end" style="color:#6B7280">-@quote.DiscountTotal.ToString("F2")</td>
                    </tr>
                }
                @if (quote.TaxRatePercent > 0)
                {
                    <tr>
                        <td colspan="4" class="text-end" style="color:#6B7280">@quote.TaxRateName (@quote.TaxRatePercent.ToString("0.##")%)</td>
                        <td class="text-end" style="color:#6B7280">+@quote.TaxAmount.ToString("F2")</td>
                    </tr>
                }
                <tr class="qprint-total-row">
                    <td colspan="4" class="text-end">Grand Total (@quote.Currency)</td>
                    <td class="text-end">@quote.GrandTotal.ToString("F2")</td>
                </tr>
            </tfoot>
        </table>

        @if (!string.IsNullOrWhiteSpace(quote.Notes))
        {
            <div class="qprint-notes">
                <strong>Notes:</strong> @quote.Notes
            </div>
        }

        <div class="qprint-footer">Thank you for your business.</div>
    </div>
}

<style>
    .qprint-layout { display: none; }

    @@media print {
        body * { visibility: hidden; }
        .qprint-layout, .qprint-layout * { visibility: visible; display: revert; }
        .qprint-layout {
            display: block !important;
            position: fixed;
            inset: 0;
            padding: 2.5cm 2cm;
            background: #fff;
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 11pt;
            color: #111;
        }
        .qprint-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #111;
        }
        .qprint-company { font-size: 20pt; font-weight: 700; }
        .qprint-sub { font-size: 10pt; color: #555; margin-top: 2px; }
        .qprint-num { font-size: 14pt; font-weight: 700; }
        .qprint-meta { font-size: 9pt; color: #555; }
        .qprint-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1.5rem;
        }
        .qprint-table th {
            border-bottom: 1px solid #555;
            padding: 6px 8px;
            font-size: 9pt;
            text-transform: uppercase;
            letter-spacing: .04em;
        }
        .qprint-table td { padding: 6px 8px; border-bottom: 1px solid #E5E7EB; }
        .qprint-total-row td { font-weight: 700; border-top: 2px solid #111; border-bottom: none; }
        .text-end { text-align: right; }
        .qprint-notes {
            border: 1px solid #E5E7EB;
            border-radius: 4px;
            padding: .75rem 1rem;
            font-size: 10pt;
            margin-bottom: 2rem;
        }
        .qprint-footer {
            text-align: center;
            font-size: 9pt;
            color: #9CA3AF;
            margin-top: 2rem;
        }
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private QuoteDetailDto? quote;
    private OrderDetailDto? order;
    private string? error;

    // Line item form
    private bool showLineItemForm;
    private ProductDto? _liProduct;
    private int liQuantity = 1;
    private decimal liUnitPrice;
    private decimal liDiscount;
    private bool liSaving;
    private string? liError;

    // Actions
    private bool actionSaving;
    private string? actionError;
    private string? actionSuccess;
    private bool showRejectForm;
    private string? rejectReason;
    private bool _taxRemoving;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { quote = await Api.GetQuoteAsync(Id); }
        catch { error = "Failed to load quote."; }

        if (quote?.Status == "Accepted")
        {
            order = await Api.GetOrderByQuoteAsync(Id);
        }
    }

    private void ToggleAddItem()
    {
        showLineItemForm = !showLineItemForm;
        if (!showLineItemForm) { _liProduct = null; liQuantity = 1; liUnitPrice = 0; liDiscount = 0; }
    }

    private void OnProductSelected(ProductDto? p)
    {
        _liProduct = p;
        liUnitPrice = p?.Price ?? 0;
    }

    private async Task AddLineItem()
    {
        liError = null;
        if (_liProduct is null) { liError = "Please select a product."; return; }
        if (liQuantity <= 0) { liError = "Quantity must be > 0."; return; }
        if (liUnitPrice <= 0) { liError = "Unit price must be > 0."; return; }

        liSaving = true;
        try
        {
            var resp = await Api.AddLineItemAsync(Id, new
            {
                ProductId = _liProduct.Id, ProductName = _liProduct.Name,
                Quantity = liQuantity, UnitPrice = liUnitPrice, DiscountPercent = liDiscount
            });
            if (resp.IsSuccessStatusCode)
            {
                showLineItemForm = false;
                _liProduct = null; liQuantity = 1; liUnitPrice = 0; liDiscount = 0;
                await Load();
            }
            else liError = await resp.Content.ReadAsStringAsync();
        }
        finally { liSaving = false; }
    }

    private async Task Send()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.SendQuoteAsync(Id);
            if (resp.IsSuccessStatusCode) { actionSuccess = "Quote sent to customer."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Accept()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.AcceptQuoteAsync(Id);
            if (resp.IsSuccessStatusCode)
            {
                actionSuccess = "Quote accepted. Order created automatically.";
                await Load();
            }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task Reject()
    {
        actionError = null; actionSuccess = null; actionSaving = true;
        try
        {
            var resp = await Api.RejectQuoteAsync(Id, rejectReason);
            if (resp.IsSuccessStatusCode) { showRejectForm = false; actionSuccess = "Quote rejected."; await Load(); }
            else actionError = await resp.Content.ReadAsStringAsync();
        }
        finally { actionSaving = false; }
    }

    private async Task RemoveTax()
    {
        _taxRemoving = true;
        try
        {
            var resp = await Api.RemoveQuoteTaxAsync(Id);
            if (resp.IsSuccessStatusCode) await Load();
        }
        finally { _taxRemoving = false; }
    }

    private async Task PrintQuote() => await JS.InvokeVoidAsync("window.print");

    private static string GetStatusBadge(string status) => status switch
    {
        "Accepted" => "bg-success",
        "Rejected" => "bg-danger",
        "Sent" => "bg-info text-dark",
        "Expired" => "bg-secondary",
        _ => "bg-warning text-dark"
    };
}
