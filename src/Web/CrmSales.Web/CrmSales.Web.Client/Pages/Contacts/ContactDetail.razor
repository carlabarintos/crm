@page "/contacts/{Id:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>@(contact?.FullName ?? "Contact")</PageTitle>

@if (contact is null && error is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (contact is not null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/contacts">Contacts</a></li>
            <li class="breadcrumb-item active">@contact.FullName</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-7">
            @if (!editing)
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="contact-avatar-lg">@contact.FirstName[0]@contact.LastName[0]</div>
                            <div>
                                <h5 class="mb-0">@contact.FullName</h5>
                                <small class="text-muted">@(contact.JobTitle ?? "")@(contact.JobTitle != null && contact.Company != null ? " · " : "")@(contact.Company ?? "")</small>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-primary" @onclick="StartEdit">Edit</button>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@(contact.Email ?? "-")</dd>
                            <dt class="col-sm-4">Phone</dt>
                            <dd class="col-sm-8">@(contact.Phone ?? "-")</dd>
                            <dt class="col-sm-4">Company</dt>
                            <dd class="col-sm-8">@(contact.Company ?? "-")</dd>
                            <dt class="col-sm-4">Job Title</dt>
                            <dd class="col-sm-8">@(contact.JobTitle ?? "-")</dd>
                            <dt class="col-sm-4">Notes</dt>
                            <dd class="col-sm-8">@(contact.Notes ?? "-")</dd>
                            <dt class="col-sm-4">Created</dt>
                            <dd class="col-sm-8">@contact.CreatedAt.ToString("MMM dd, yyyy")</dd>
                        </dl>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header"><h6 class="mb-0">Edit Contact</h6></div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">First Name <span class="text-danger">*</span></label>
                                <input class="form-control" @bind="editFirst" />
                            </div>
                            <div class="col">
                                <label class="form-label">Last Name <span class="text-danger">*</span></label>
                                <input class="form-control" @bind="editLast" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">Email</label>
                                <input class="form-control" type="email" @bind="editEmail" />
                            </div>
                            <div class="col">
                                <label class="form-label">Phone</label>
                                <input class="form-control" @bind="editPhone" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">Company</label>
                                <input class="form-control" @bind="editCompany" />
                            </div>
                            <div class="col">
                                <label class="form-label">Job Title</label>
                                <input class="form-control" @bind="editJobTitle" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" @bind="editNotes" rows="3"></textarea>
                        </div>
                        @if (!string.IsNullOrEmpty(editError)) { <div class="alert alert-danger">@editError</div> }
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="SaveEdit" disabled="@saving">
                            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save Changes
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => editing = false">Cancel</button>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-5">
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Quick Actions</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="/opportunities/new" class="btn btn-sm btn-outline-primary">+ New Opportunity</a>
                    <a href="/contacts" class="btn btn-sm btn-outline-secondary">Back to Contacts</a>
                    <button class="btn btn-sm btn-outline-danger mt-2" @onclick="Delete" disabled="@saving">Delete Contact</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Orders History</h6>
                    @if (orders.Count > 0)
                    {
                        <span class="badge bg-secondary rounded-pill">@orders.Count</span>
                    }
                </div>
                @if (!orders.Any())
                {
                    <div class="card-body text-center text-muted py-4">No orders yet for this contact.</div>
                }
                else
                {
                    <div class="card-body p-3">
                        <div class="order-tl">
                            @for (int oi = 0; oi < orders.Count; oi++)
                            {
                                var order = orders[oi];
                                var steps = GetStatusSteps(order);
                                var isExpanded = expandedOrders.Contains(order.Id);
                                var isLast = oi == orders.Count - 1;
                                <div class="order-tl-item">
                                    <div class="order-tl-line-col">
                                        <div class="order-tl-dot @StatusDotClass(order.Status)"></div>
                                        @if (!isLast) { <div class="order-tl-connector"></div> }
                                    </div>
                                    <div class="order-tl-body">
                                        <div class="order-tl-date">@order.CreatedAt.ToString("MMM dd, yyyy")</div>
                                        <div class="card order-tl-card @(isLast ? "mb-0" : "mb-3")">
                                            <div class="card-body pb-2">
                                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                                    <div>
                                                        <a href="/orders/@order.Id" class="fw-semibold order-num">@order.OrderNumber</a>
                                                        <span class="badge ms-2 @StatusBadgeClass(order.Status)">@order.Status</span>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="fw-semibold">@order.GrandTotal.ToString("N2") @order.Currency</span>
                                                    </div>
                                                </div>

                                                <div class="status-stepper">
                                                    @for (int si = 0; si < steps.Count; si++)
                                                    {
                                                        var step = steps[si];
                                                        <div class="step-item @step.State">
                                                            <div class="step-dot"></div>
                                                            <div class="step-label">@step.Label</div>
                                                            @if (step.Date.HasValue)
                                                            {
                                                                <div class="step-date">@step.Date.Value.ToString("MMM d")</div>
                                                            }
                                                        </div>
                                                        @if (si < steps.Count - 1)
                                                        {
                                                            <div class="step-connector @(step.State == "step-completed" ? "filled" : "")"></div>
                                                        }
                                                    }
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(order.ShippingAddress))
                                                {
                                                    <div class="text-muted small mt-2">Ship to: @order.ShippingAddress</div>
                                                }
                                            </div>
                                            @if (order.LineItems.Any())
                                            {
                                                <div class="card-footer py-2 d-flex justify-content-between align-items-center">
                                                    <span class="text-muted small">@order.LineItems.Count item@(order.LineItems.Count != 1 ? "s" : "")</span>
                                                    <button class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => ToggleOrder(order.Id)">
                                                        @(isExpanded ? "Hide items ▲" : "Show items ▼")
                                                    </button>
                                                </div>
                                                @if (isExpanded)
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-sm mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th>Product</th>
                                                                    <th class="text-center">Qty</th>
                                                                    <th class="text-end">Unit Price</th>
                                                                    <th class="text-end">Total</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var item in order.LineItems)
                                                                {
                                                                    <tr>
                                                                        <td>@item.ProductName</td>
                                                                        <td class="text-center">@item.Quantity</td>
                                                                        <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                                                                        <td class="text-end fw-semibold">@item.LineTotal.ToString("N2") @order.Currency</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .contact-avatar-lg {
        width: 48px; height: 48px; border-radius: 50%;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        display: flex; align-items: center; justify-content: center;
        font-size: 15px; font-weight: 700; color: #fff; flex-shrink: 0;
        text-transform: uppercase;
    }

    .order-tl { }
    .order-tl-item { display: flex; gap: 12px; }
    .order-tl-line-col { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 18px; padding-top: 2px; }
    .order-tl-dot {
        width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0;
        border: 2px solid #fff; box-shadow: 0 0 0 2px currentColor;
    }
    .order-tl-dot.dot-success   { color: #198754; background: #198754; }
    .order-tl-dot.dot-primary   { color: #0d6efd; background: #0d6efd; }
    .order-tl-dot.dot-warning   { color: #e6a817; background: #ffc107; }
    .order-tl-dot.dot-danger    { color: #dc3545; background: #dc3545; }
    .order-tl-dot.dot-secondary { color: #6c757d; background: #6c757d; }
    .order-tl-connector { width: 2px; flex: 1; background: #dee2e6; min-height: 20px; margin: 4px 0; }
    .order-tl-body { flex: 1; min-width: 0; }
    .order-tl-date { font-size: 12px; color: #6c757d; font-weight: 500; margin-bottom: 4px; }
    .order-tl-card { border-color: #e9ecef; }
    .order-num { color: #0d6efd; text-decoration: none; }
    .order-num:hover { text-decoration: underline; }

    .status-stepper { display: flex; align-items: flex-start; overflow-x: auto; padding-bottom: 2px; }
    .step-item { display: flex; flex-direction: column; align-items: center; min-width: 58px; flex-shrink: 0; }
    .step-connector { flex: 1; height: 2px; background: #dee2e6; margin-top: 4px; min-width: 10px; }
    .step-connector.filled { background: #198754; }
    .step-dot { width: 10px; height: 10px; border-radius: 50%; background: #dee2e6; flex-shrink: 0; }
    .step-item.step-completed .step-dot { background: #198754; }
    .step-item.step-active .step-dot { background: #0d6efd; box-shadow: 0 0 0 3px rgba(13,110,253,.2); }
    .step-item.step-cancelled .step-dot { background: #dc3545; }
    .step-label { font-size: 10px; color: #adb5bd; margin-top: 3px; text-align: center; white-space: nowrap; }
    .step-item.step-completed .step-label { color: #198754; }
    .step-item.step-active .step-label { color: #0d6efd; font-weight: 600; }
    .step-item.step-cancelled .step-label { color: #dc3545; }
    .step-date { font-size: 10px; color: #6c757d; text-align: center; white-space: nowrap; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private ContactDetailDto? contact;
    private List<ContactOrderDto> orders = [];
    private string? error;
    private bool editing;
    private bool saving;
    private string? editError;
    private HashSet<Guid> expandedOrders = new();

    private string editFirst = "", editLast = "";
    private string? editEmail, editPhone, editCompany, editJobTitle, editNotes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var contactTask = Api.GetContactAsync(Id);
            var ordersTask = Api.GetContactOrdersAsync(Id);
            contact = await contactTask;
            orders = await ordersTask ?? [];
        }
        catch { error = "Failed to load contact."; }
    }

    private void ToggleOrder(Guid id)
    {
        if (!expandedOrders.Add(id)) expandedOrders.Remove(id);
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Delivered"  => "bg-success",
        "Shipped"    => "bg-warning text-dark",
        "Processing" => "bg-primary",
        "Confirmed"  => "bg-info text-dark",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };

    private static string StatusDotClass(string status) => status switch
    {
        "Delivered"  => "dot-success",
        "Shipped"    => "dot-warning",
        "Processing" => "dot-primary",
        "Confirmed"  => "dot-primary",
        "Cancelled"  => "dot-danger",
        _            => "dot-secondary"
    };

    private record StatusStep(string Label, string State, DateTime? Date);

    private static List<StatusStep> GetStatusSteps(ContactOrderDto order)
    {
        if (order.Status == "Cancelled")
            return [new("Created", "step-completed", order.CreatedAt), new("Cancelled", "step-cancelled", null)];

        int level = order.Status switch
        {
            "Pending"    => 0,
            "Confirmed"  => 1,
            "Processing" => 2,
            "Shipped"    => 3,
            "Delivered"  => 4,
            _            => 0
        };

        string S(int n) => n < level ? "step-completed" : n == level ? "step-active" : "step-upcoming";
        return [
            new("Created",    S(0), order.CreatedAt),
            new("Confirmed",  S(1), null),
            new("Processing", S(2), null),
            new("Shipped",    S(3), level >= 3 ? order.ShippedAt : null),
            new("Delivered",  S(4), level >= 4 ? order.DeliveredAt : null)
        ];
    }

    private void StartEdit()
    {
        if (contact is null) return;
        editFirst = contact.FirstName; editLast = contact.LastName;
        editEmail = contact.Email; editPhone = contact.Phone;
        editCompany = contact.Company; editJobTitle = contact.JobTitle;
        editNotes = contact.Notes;
        editing = true;
    }

    private async Task SaveEdit()
    {
        editError = null;
        if (string.IsNullOrWhiteSpace(editFirst) || string.IsNullOrWhiteSpace(editLast))
        { editError = "First and last name are required."; return; }
        saving = true;
        try
        {
            var resp = await Api.UpdateContactAsync(Id, new
            {
                FirstName = editFirst, LastName = editLast,
                Email = editEmail, Phone = editPhone,
                Company = editCompany, JobTitle = editJobTitle, Notes = editNotes
            });
            if (resp.IsSuccessStatusCode)
            {
                contact = await Api.GetContactAsync(Id);
                editing = false;
            }
            else editError = await resp.Content.ReadAsStringAsync();
        }
        finally { saving = false; }
    }

    private async Task Delete()
    {
        saving = true;
        try
        {
            var resp = await Api.DeleteContactAsync(Id);
            if (resp.IsSuccessStatusCode) Nav.NavigateTo("/contacts");
            else error = await resp.Content.ReadAsStringAsync();
        }
        finally { saving = false; }
    }
}
