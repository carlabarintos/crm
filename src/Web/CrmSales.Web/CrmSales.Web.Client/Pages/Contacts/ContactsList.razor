@page "/contacts"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Contacts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Contacts</h4>
        <p class="text-muted small mb-0">Manage your customer contacts</p>
    </div>
    <div class="d-flex gap-2">
        @if (contacts.Any())
        {
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportCsv">Export CSV</button>
        }
        <a href="/contacts/new" class="btn btn-primary btn-sm">+ New Contact</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <input class="form-control form-control-sm" style="max-width:320px"
               @bind="search" @onkeyup="OnSearchKey"
               placeholder="Search by name, email, company…" />
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (!contacts.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:2rem">&#128100;</div>
            <p class="mt-2">No contacts yet. <a href="/contacts/new">Create your first contact</a>.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Company</th>
                        <th>Job Title</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in contacts)
                    {
                        var contactId = c.Id;
                        <tr style="cursor:pointer" @onclick="@(() => GoToContact(contactId))">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="contact-avatar">@c.FirstName[0]@c.LastName[0]</div>
                                    <span class="fw-medium">@c.FullName</span>
                                </div>
                            </td>
                            <td class="text-muted">@(c.Email ?? "-")</td>
                            <td class="text-muted">@(c.Phone ?? "-")</td>
                            <td class="text-muted">@(c.Company ?? "-")</td>
                            <td class="text-muted">@(c.JobTitle ?? "-")</td>
                            <td class="text-end">
                                <a href="/contacts/@c.Id" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation>View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (hasMore)
{
    <div class="text-center py-3">
        <button class="btn btn-outline-primary btn-sm" @onclick="LoadMore" disabled="@isLoadingMore">
            @if (isLoadingMore) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Load More
        </button>
    </div>
}

<style>
    .contact-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0;
        text-transform: uppercase;
    }
</style>

@code {
    private List<ContactDto> contacts = [];
    private string search = "";
    private string? cursor;
    private bool hasMore;
    private bool isLoadingMore;
    private bool _loading = true;

    private void GoToContact(Guid id) => Nav.NavigateTo("/contacts/" + id);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        cursor = null;
        var result = await Api.GetContactsAsync(
            string.IsNullOrWhiteSpace(search) ? null : search, 20, null);
        contacts = result?.Items ?? [];
        cursor = result?.NextCursor;
        hasMore = result?.HasMore ?? false;
        _loading = false;
    }

    private async Task LoadMore()
    {
        if (isLoadingMore || !hasMore) return;
        isLoadingMore = true;
        try
        {
            var result = await Api.GetContactsAsync(
                string.IsNullOrWhiteSpace(search) ? null : search, 20, cursor);
            contacts.AddRange(result?.Items ?? []);
            cursor = result?.NextCursor;
            hasMore = result?.HasMore ?? false;
        }
        finally { isLoadingMore = false; }
    }

    private async Task ExportCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Name,Email,Phone,Company,Job Title");
        foreach (var c in contacts)
            sb.AppendLine($"\"{c.FullName}\",\"{c.Email ?? ""}\",\"{c.Phone ?? ""}\",\"{c.Company ?? ""}\",\"{c.JobTitle ?? ""}\"");
        await JS.InvokeVoidAsync("downloadCsv", $"contacts_{DateTime.Today:yyyyMMdd}.csv", sb.ToString());
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Load();
    }
}
