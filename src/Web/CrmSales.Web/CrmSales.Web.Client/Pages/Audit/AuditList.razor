@page "/audit"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,SalesManager")]
@inject CrmApiClient Api

<PageTitle>Audit Log</PageTitle>

<div class="page-header stagger-1">
    <div>
        <p class="page-header-meta">Admin</p>
        <h1>Audit Log</h1>
    </div>
</div>

@if (data is null)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else
{
    <div class="card stagger-2">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:160px">When</th>
                        <th style="width:120px">Actor</th>
                        <th style="width:160px">Event</th>
                        <th style="width:100px">Entity</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!data.Items.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No audit entries yet.</td></tr>
                    }
                    @foreach (var a in data.Items)
                    {
                        <tr>
                            <td class="text-muted" style="font-size:12px;white-space:nowrap">@a.OccurredAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                            <td style="font-size:12px;font-weight:600">@a.Actor</td>
                            <td><span class="badge @GetEventBadge(a.EventType)" style="font-size:11px">@FormatEventType(a.EventType)</span></td>
                            <td class="text-muted" style="font-size:12px">@a.EntityType</td>
                            <td style="font-size:12.5px">@a.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (data.Total > data.PageSize)
    {
        var totalPages = (int)Math.Ceiling((double)data.Total / data.PageSize);
        <div class="d-flex justify-content-between align-items-center mt-3 stagger-3">
            <span class="text-muted small">@data.Total entries total</span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">← Prev</button>
                <span class="btn btn-sm btn-light disabled">@_page / @totalPages</span>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(_page >= totalPages)" @onclick="NextPage">Next →</button>
            </div>
        </div>
    }
}

@code {
    private AuditPageDto? data;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        data = null;
        data = await Api.GetAuditLogsAsync(_page, 50);
    }

    private async Task PrevPage() { _page--; await Load(); }
    private async Task NextPage() { _page++; await Load(); }

    private static string GetEventBadge(string type) => type switch
    {
        var t when t.EndsWith(".won") || t.EndsWith(".delivered") || t.EndsWith(".accepted") => "badge-soft-success",
        var t when t.EndsWith(".cancelled") || t.EndsWith(".rejected") => "badge-soft-danger",
        var t when t.EndsWith(".shipped") || t.EndsWith(".sent") => "badge-soft-info",
        var t when t.EndsWith(".created") => "badge-soft-primary",
        _ => "badge-soft-neutral"
    };

    private static string FormatEventType(string type)
    {
        var parts = type.Split('.');
        return parts.Length == 2
            ? $"{char.ToUpper(parts[1][0])}{parts[1][1..]} {char.ToUpper(parts[0][0])}{parts[0][1..]}"
            : type;
    }
}
