@page "/products/new"
@page "/products/{Id:guid}/edit"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>@(Id.HasValue ? "Edit Product" : "New Product")</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/products">Products</a></li>
        <li class="breadcrumb-item active">@(Id.HasValue ? "Edit" : "New")</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">@(Id.HasValue ? "Edit Product" : "Create Product")</h5></div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="name" placeholder="Product name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">SKU <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="sku" placeholder="e.g. PRD-001" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" @bind="description" rows="3" placeholder="Optional description"></textarea>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Price <span class="text-danger">*</span></label>
                        <input class="form-control" type="number" step="0.01" @bind="price" />
                    </div>
                    <div class="col">
                        <label class="form-label">Currency</label>
                        <select class="form-select" @bind="currency">
                            <option>PHP</option>
                            <option>USD</option>
                            <option>EUR</option>
                            <option>GBP</option>
                            <option>AUD</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Category <span class="text-danger">*</span></label>
                    <div class="d-flex gap-2">
                        <select class="form-select" @bind="categoryId">
                            @if (categories is null)
                            {
                                <option value="@Guid.Empty">Loading…</option>
                            }
                            else
                            {
                                <option value="@Guid.Empty">— Select category —</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                        <button type="button" class="btn btn-outline-secondary btn-sm text-nowrap"
                                @onclick="() => showNewCategory = !showNewCategory">
                            + New
                        </button>
                    </div>
                    @if (showNewCategory)
                    {
                        <div class="card mt-2">
                            <div class="card-body p-2">
                                <div class="mb-2">
                                    <input class="form-control form-control-sm" @bind="newCategoryName"
                                           placeholder="Category name *" />
                                </div>
                                <div class="mb-2">
                                    <input class="form-control form-control-sm" @bind="newCategoryDescription"
                                           placeholder="Description (optional)" />
                                </div>
                                @if (!string.IsNullOrEmpty(newCategoryError))
                                {
                                    <div class="text-danger small mb-1">@newCategoryError</div>
                                }
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-primary btn-sm"
                                            @onclick="AddCategory" disabled="@newCategorySaving">
                                        @if (newCategorySaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Save Category
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            @onclick="() => showNewCategory = false">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Stock Quantity</label>
                    <input class="form-control" type="number" @bind="stockQuantity" />
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @(Id.HasValue ? "Save Changes" : "Create Product")
                </button>
                <a href="/products" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private string name = "";
    private string sku = "";
    private string? description;
    private decimal price;
    private string currency = "PHP";
    private int stockQuantity;
    private Guid categoryId;
    private List<CategoryDto>? categories;
    private bool saving;
    private string? error;

    private bool showNewCategory;
    private string newCategoryName = "";
    private string? newCategoryDescription;
    private bool newCategorySaving;
    private string? newCategoryError;

    protected override async Task OnInitializedAsync()
    {
        categories = await Api.GetCategoriesAsync();
        if (categories?.Any() == true && categoryId == Guid.Empty)
            categoryId = categories[0].Id;

        if (Id.HasValue)
        {
            var p = await Api.GetProductAsync(Id.Value);
            if (p is not null)
            {
                name = p.Name;
                sku = p.Sku;
                description = p.Description;
                price = p.Price;
                currency = p.Currency;
                stockQuantity = p.StockQuantity;
                categoryId = p.CategoryId;
            }
        }
    }

    private async Task AddCategory()
    {
        newCategoryError = null;
        if (string.IsNullOrWhiteSpace(newCategoryName))
        { newCategoryError = "Category name is required."; return; }

        newCategorySaving = true;
        try
        {
            var resp = await Api.CreateCategoryAsync(new { Name = newCategoryName, Description = newCategoryDescription });
            if (resp.IsSuccessStatusCode)
            {
                categories = await Api.GetCategoriesAsync();
                var created = categories?.FirstOrDefault(c =>
                    string.Equals(c.Name, newCategoryName.Trim(), StringComparison.OrdinalIgnoreCase));
                if (created is not null) categoryId = created.Id;
                newCategoryName = "";
                newCategoryDescription = null;
                showNewCategory = false;
            }
            else
                newCategoryError = await resp.Content.ReadAsStringAsync();
        }
        finally { newCategorySaving = false; }
    }

    private async Task Save()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(sku) || price <= 0)
        {
            error = "Name, SKU and a positive Price are required.";
            return;
        }
        if (categoryId == Guid.Empty)
        {
            error = "Please select a category.";
            return;
        }

        saving = true;
        try
        {
            HttpResponseMessage resp;
            if (Id.HasValue)
            {
                resp = await Api.UpdateProductAsync(Id.Value, new
                {
                    Id = Id.Value, Name = name, Description = description,
                    Sku = sku, Price = price, Currency = currency,
                    CategoryId = categoryId, StockQuantity = stockQuantity
                });
            }
            else
            {
                resp = await Api.CreateProductAsync(new
                {
                    Name = name, Description = description,
                    Sku = sku, Price = price, Currency = currency,
                    CategoryId = categoryId, StockQuantity = stockQuantity
                });
            }

            if (resp.IsSuccessStatusCode)
                Nav.NavigateTo("/products");
            else
                error = await resp.Content.ReadAsStringAsync();
        }
        finally { saving = false; }
    }
}
