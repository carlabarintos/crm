@page "/products"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api

<PageTitle>Products</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Products</h1>
    <a href="/products/new" class="btn btn-primary">+ New Product</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by name or SKU..." @bind="searchTerm" @bind:after="LoadProducts" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="activeFilter" @bind:after="LoadProducts">
            <option value="">All</option>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </select>
    </div>
</div>

@if (products is null)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else if (!products.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in products)
        {
            <div class="col">
                <div class="card h-100 @(p.IsActive ? "" : "opacity-50")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">@p.Name</h5>
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <p class="text-muted small">SKU: @p.Sku</p>
                        <p class="card-text">@p.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-primary">@p.Price.ToString("F2") @p.Currency</span>
                            <span class="text-muted small">Stock: @p.StockQuantity</span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/products/@p.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ProductDto>? products;
    private string searchTerm = "";
    private string activeFilter = "";

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        bool? isActive = activeFilter switch { "true" => true, "false" => false, _ => null };
        products = await Api.GetProductsAsync(
            string.IsNullOrEmpty(searchTerm) ? null : searchTerm, isActive);
    }
}
