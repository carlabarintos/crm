@page "/products"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api

<PageTitle>Products</PageTitle>

<div class="page-header stagger-1">
    <div>
        <p class="page-header-meta">Catalog</p>
        <h1>Products</h1>
    </div>
    <a href="/products/new" class="btn btn-primary">+ New Product</a>
</div>

<!-- Summary cards -->
@if (products is not null)
{
    <button type="button" class="mob-section-btn @(_statsOpen ? "open" : "")" @onclick="() => _statsOpen = !_statsOpen">
        <span>Summary</span>
        <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
    </button>
    <div class="mob-collapse @(_statsOpen ? "open" : "")">
    <div class="row g-3 mb-4 stagger-2">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Active Products</div>
                <div class="stat-card-value text-primary">@ActiveCount</div>
                <div class="stat-card-sub">of @products.Count total</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Low Stock</div>
                <div class="stat-card-value" style="color:#D97706">@LowStockCount</div>
                <div class="stat-card-sub">1–10 units remaining</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Out of Stock</div>
                <div class="stat-card-value text-danger">@OutOfStockCount</div>
                <div class="stat-card-sub">0 units available</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Inventory Value</div>
                <div class="stat-card-value text-success">@FormatInventoryValue()</div>
                <div class="stat-card-sub">active products only</div>
            </div>
        </div>
    </div>
    </div>
}

<button type="button" class="mob-section-btn @(_filtersOpen ? "open" : "")" @onclick="() => _filtersOpen = !_filtersOpen">
    <span>Filters</span>
    <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
</button>
<div class="mob-collapse @(_filtersOpen ? "open" : "")">
<div class="row mb-3 stagger-3">
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by name or SKU..." @bind="searchTerm" @bind:after="LoadProducts" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="activeFilter" @bind:after="LoadProducts">
            <option value="">All</option>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </select>
    </div>
</div>
</div>

@if (products is null)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else if (!products.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in products)
        {
            <div class="col">
                <div class="card h-100 @(p.IsActive ? "" : "opacity-50")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">@p.Name</h5>
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <p class="text-muted small">SKU: @p.Sku</p>
                        <p class="card-text">@p.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-primary">@p.Price.ToString("F2") @p.Currency</span>
                            <span class="text-muted small">Stock: @p.StockQuantity</span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/products/@p.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .stat-card {
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }
    .stat-card-label {
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #9CA3AF;
        margin-bottom: .3rem;
    }
    .stat-card-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
        margin-bottom: .2rem;
    }
    .stat-card-sub { font-size: 11.5px; color: #9CA3AF; }
</style>

@code {
    private List<ProductDto>? products;
    private string searchTerm = "";
    private string activeFilter = "";
    private bool _statsOpen = true;
    private bool _filtersOpen = true;

    private int ActiveCount => (products ?? []).Count(p => p.IsActive);
    private int LowStockCount => (products ?? []).Count(p => p.IsActive && p.StockQuantity > 0 && p.StockQuantity <= 10);
    private int OutOfStockCount => (products ?? []).Count(p => p.IsActive && p.StockQuantity == 0);
    private decimal InventoryValue => (products ?? []).Where(p => p.IsActive).Sum(p => p.Price * p.StockQuantity);

    private string FormatInventoryValue()
    {
        var sym = products?.FirstOrDefault()?.Currency switch
        {
            "PHP" => "₱", "USD" => "$", "EUR" => "€", "GBP" => "£", var c => (c ?? "") + " "
        };
        return InventoryValue >= 1_000_000 ? $"{sym}{InventoryValue / 1_000_000:N1}M"
             : InventoryValue >= 1_000     ? $"{sym}{InventoryValue / 1_000:N1}K"
             : $"{sym}{InventoryValue:N0}";
    }

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        bool? isActive = activeFilter switch { "true" => true, "false" => false, _ => null };
        products = await Api.GetProductsAsync(
            string.IsNullOrEmpty(searchTerm) ? null : searchTerm, isActive);
    }
}
