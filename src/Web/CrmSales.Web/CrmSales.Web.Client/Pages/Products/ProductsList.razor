@page "/products"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject CrmApiClient Api
@inject IJSRuntime JS

<PageTitle>Products</PageTitle>

<div class="page-header stagger-1">
    <div>
        <p class="page-header-meta">Catalog</p>
        <h1>Products</h1>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadTemplate">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-right:4px;vertical-align:-1px"><path d="M6.5 1v7M4 6l2.5 2.5L9 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 10v1a1 1 0 001 1h9a1 1 0 001-1v-1" stroke-linecap="round"/></svg>
            CSV Template
        </button>
        <button class="btn btn-outline-primary btn-sm" @onclick="() => { _showImport = !_showImport; ResetImport(); }">
            Import CSV
        </button>
        <a href="/products/new" class="btn btn-primary btn-sm">+ New Product</a>
    </div>
</div>

<!-- CSV Import Panel -->
@if (_showImport)
{
    <div class="card mb-4 stagger-2">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0">Import Products from CSV</h6>
            <span class="text-muted" style="font-size:11.5px">Max 200 rows · Matched by SKU (existing skipped)</span>
        </div>
        <div class="card-body">
            @if (_importResult is null)
            {
                <div class="mb-3">
                    <label class="form-label">Select CSV file</label>
                    <InputFile class="form-control" accept=".csv,text/csv" OnChange="OnFileSelected" />
                    @if (!string.IsNullOrEmpty(_importParseError))
                    {
                        <div class="text-danger small mt-1">@_importParseError</div>
                    }
                </div>

                @if (_importPreview.Count > 0)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Preview — @_importPreview.Count row@(_importPreview.Count == 1 ? "" : "s") ready to import</span>
                        </div>
                        <div class="table-responsive" style="max-height:240px;overflow-y:auto">
                            <table class="table table-sm table-bordered mb-0" style="font-size:12px">
                                <thead class="table-light sticky-top">
                                    <tr><th>#</th><th>Name</th><th>SKU</th><th>Price</th><th>Currency</th><th>Stock</th><th>Category</th></tr>
                                </thead>
                                <tbody>
                                    @{ int rn = 0; }
                                    @foreach (var row in _importPreview)
                                    {
                                        rn++;
                                        bool hasError = string.IsNullOrWhiteSpace(row.Name) || string.IsNullOrWhiteSpace(row.Sku) || row.Price <= 0;
                                        <tr class="@(hasError ? "table-warning" : "")">
                                            <td class="text-muted">@rn</td>
                                            <td>@row.Name</td>
                                            <td style="font-family:monospace">@row.Sku</td>
                                            <td>@row.Price.ToString("F2")</td>
                                            <td>@row.Currency</td>
                                            <td>@row.StockQuantity</td>
                                            <td style="color:#6B7280">@(row.CategoryName ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="RunImport" disabled="@_importing">
                        @if (_importing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Import @_importPreview.Count @(_importPreview.Count == 1 ? "product" : "products")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="ResetImport">Clear</button>
                }
            }
            else
            {
                <div class="import-result">
                    <div class="d-flex gap-3 mb-3 flex-wrap">
                        <div class="import-stat import-stat-success">
                            <div class="import-stat-val">@_importResult.Created</div>
                            <div class="import-stat-lbl">Created</div>
                        </div>
                        <div class="import-stat import-stat-neutral">
                            <div class="import-stat-val">@_importResult.Skipped</div>
                            <div class="import-stat-lbl">Skipped (SKU exists)</div>
                        </div>
                        @if (_importResult.Errors.Count > 0)
                        {
                            <div class="import-stat import-stat-danger">
                                <div class="import-stat-val">@_importResult.Errors.Count</div>
                                <div class="import-stat-lbl">Errors</div>
                            </div>
                        }
                    </div>
                    @if (_importResult.Errors.Count > 0)
                    {
                        <div class="alert alert-warning py-2 mb-3" style="font-size:12.5px">
                            @foreach (var e in _importResult.Errors) { <div>Row @e.Row: @e.Reason</div> }
                        </div>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ResetImport">Import another file</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showImport = false">Close</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Summary cards -->
@if (products is not null)
{
    <button type="button" class="mob-section-btn @(_statsOpen ? "open" : "")" @onclick="() => _statsOpen = !_statsOpen">
        <span>Summary</span>
        <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
    </button>
    <div class="mob-collapse @(_statsOpen ? "open" : "")">
    <div class="row g-3 mb-4 stagger-2">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Active Products</div>
                <div class="stat-card-value text-primary">@ActiveCount</div>
                <div class="stat-card-sub">of @products.Count total</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Low Stock</div>
                <div class="stat-card-value" style="color:#D97706">@LowStockCount</div>
                <div class="stat-card-sub">1–10 units remaining</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Out of Stock</div>
                <div class="stat-card-value text-danger">@OutOfStockCount</div>
                <div class="stat-card-sub">0 units available</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Inventory Value</div>
                <div class="stat-card-value text-success">@FormatInventoryValue()</div>
                <div class="stat-card-sub">active products only</div>
            </div>
        </div>
    </div>
    </div>
}

<button type="button" class="mob-section-btn @(_filtersOpen ? "open" : "")" @onclick="() => _filtersOpen = !_filtersOpen">
    <span>Filters</span>
    <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
</button>
<div class="mob-collapse @(_filtersOpen ? "open" : "")">
<div class="row mb-3 stagger-3">
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by name or SKU..." @bind="searchTerm" @bind:after="LoadProducts" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="activeFilter" @bind:after="LoadProducts">
            <option value="">All</option>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </select>
    </div>
</div>
</div>

@if (products is null)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else if (!products.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in products)
        {
            <div class="col">
                <div class="card h-100 @(p.IsActive ? "" : "opacity-50")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">@p.Name</h5>
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <p class="text-muted small">SKU: @p.Sku</p>
                        <p class="card-text">@p.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-primary">@p.Price.ToString("F2") @p.Currency</span>
                            <span class="text-muted small">Stock: @p.StockQuantity</span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/products/@p.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .stat-card {
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }
    .stat-card-label {
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #9CA3AF;
        margin-bottom: .3rem;
    }
    .stat-card-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
        margin-bottom: .2rem;
    }
    .stat-card-sub { font-size: 11.5px; color: #9CA3AF; }

    .import-stat {
        display: flex; flex-direction: column; align-items: center;
        padding: .6rem 1.25rem; border-radius: 10px; min-width: 80px;
    }
    .import-stat-val { font-size: 1.5rem; font-weight: 700; line-height: 1.1; }
    .import-stat-lbl { font-size: 10.5px; color: #6B7280; margin-top: 2px; white-space: nowrap; }
    .import-stat-success { background: #ECFDF5; }
    .import-stat-success .import-stat-val { color: #059669; }
    .import-stat-neutral { background: #F9FAFB; }
    .import-stat-neutral .import-stat-val { color: #374151; }
    .import-stat-danger { background: #FEF2F2; }
    .import-stat-danger .import-stat-val { color: #DC2626; }
</style>

@code {
    private List<ProductDto>? products;
    private string searchTerm = "";
    private string activeFilter = "";
    private bool _statsOpen = true;
    private bool _filtersOpen = true;

    // Import
    private bool _showImport;
    private bool _importing;
    private string? _importParseError;
    private List<ProductImportRow> _importPreview = [];
    private ImportResult? _importResult;

    private const int MaxImportRows = 200;
    private const long MaxFileSizeBytes = 512 * 1024; // 512 KB

    private int ActiveCount => (products ?? []).Count(p => p.IsActive);
    private int LowStockCount => (products ?? []).Count(p => p.IsActive && p.StockQuantity > 0 && p.StockQuantity <= 10);
    private int OutOfStockCount => (products ?? []).Count(p => p.IsActive && p.StockQuantity == 0);
    private decimal InventoryValue => (products ?? []).Where(p => p.IsActive).Sum(p => p.Price * p.StockQuantity);

    private record ProductImportRow(string Name, string Sku, string? Description, decimal Price, string Currency, int StockQuantity, string? CategoryName);

    private string FormatInventoryValue()
    {
        var sym = products?.FirstOrDefault()?.Currency switch
        {
            "PHP" => "₱", "USD" => "$", "EUR" => "€", "GBP" => "£", var c => (c ?? "") + " "
        };
        return InventoryValue >= 1_000_000 ? $"{sym}{InventoryValue / 1_000_000:N1}M"
             : InventoryValue >= 1_000     ? $"{sym}{InventoryValue / 1_000:N1}K"
             : $"{sym}{InventoryValue:N0}";
    }

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        bool? isActive = activeFilter switch { "true" => true, "false" => false, _ => null };
        products = await Api.GetProductsAsync(
            string.IsNullOrEmpty(searchTerm) ? null : searchTerm, isActive);
    }

    // ── CSV Import ────────────────────────────────────────────────────────────

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _importParseError = null;
        _importPreview = [];
        _importResult = null;

        var file = e.File;
        if (file.Size > MaxFileSizeBytes)
        {
            _importParseError = "File too large. Maximum size is 512 KB.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(MaxFileSizeBytes);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var rows = ParseProductCsv(content);

            if (rows.Count > MaxImportRows)
            {
                _importParseError = $"CSV contains {rows.Count} data rows. Maximum is {MaxImportRows}.";
                return;
            }

            _importPreview = rows;
        }
        catch (Exception ex)
        {
            _importParseError = $"Failed to read file: {ex.Message}";
        }
    }

    private static List<ProductImportRow> ParseProductCsv(string content)
    {
        var result = new List<ProductImportRow>();
        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        bool isFirst = true;

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd('\r').Trim();
            if (string.IsNullOrEmpty(line)) continue;

            var cols = SplitCsvLine(line);

            if (isFirst)
            {
                isFirst = false;
                if (cols.Count > 0 && cols[0].Trim().Equals("Name", StringComparison.OrdinalIgnoreCase))
                    continue;
            }

            var name     = cols.Count > 0 ? cols[0].Trim() : "";
            var sku      = cols.Count > 1 ? cols[1].Trim() : "";
            var desc     = cols.Count > 2 ? cols[2].Trim() : "";
            var priceStr = cols.Count > 3 ? cols[3].Trim() : "0";
            var currency = cols.Count > 4 ? cols[4].Trim().ToUpperInvariant() : "USD";
            var stockStr = cols.Count > 5 ? cols[5].Trim() : "0";
            var catName  = cols.Count > 6 ? cols[6].Trim() : "";

            decimal.TryParse(priceStr, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var price);
            int.TryParse(stockStr, out var stock);
            if (string.IsNullOrEmpty(currency)) currency = "USD";

            result.Add(new ProductImportRow(
                name, sku,
                string.IsNullOrEmpty(desc) ? null : desc,
                price, currency, stock,
                string.IsNullOrEmpty(catName) ? null : catName));
        }

        return result;
    }

    private static List<string> SplitCsvLine(string line)
    {
        var result = new List<string>();
        var sb = new System.Text.StringBuilder();
        bool inQuotes = false;

        for (int i = 0; i < line.Length; i++)
        {
            char c = line[i];
            if (c == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"') { sb.Append('"'); i++; }
                else inQuotes = !inQuotes;
            }
            else if (c == ',' && !inQuotes) { result.Add(sb.ToString()); sb.Clear(); }
            else sb.Append(c);
        }
        result.Add(sb.ToString());
        return result;
    }

    private async Task RunImport()
    {
        if (_importPreview.Count == 0) return;
        _importing = true;
        try
        {
            var payload = _importPreview.Select(r => new
            {
                r.Name, r.Sku, r.Description, r.Price, r.Currency, r.StockQuantity, r.CategoryName
            }).ToList();

            var resp = await Api.ImportProductsAsync(payload);
            if (resp.IsSuccessStatusCode)
            {
                _importResult = await resp.Content.ReadFromJsonAsync<ImportResult>();
                await LoadProducts();
            }
            else
            {
                _importParseError = $"Import failed: {await resp.Content.ReadAsStringAsync()}";
            }
        }
        finally { _importing = false; }
    }

    private void ResetImport()
    {
        _importPreview = [];
        _importParseError = null;
        _importResult = null;
    }

    private async Task DownloadTemplate()
    {
        var csv = "Name,SKU,Description,Price,Currency,StockQuantity,CategoryName\n" +
                  "\"Sample Widget\",SKU-001,\"A sample product description\",99.99,USD,50,Electronics\n" +
                  "\"Another Product\",SKU-002,,149.00,USD,25,Clothing";
        await JS.InvokeVoidAsync("downloadCsv", "products_template.csv", csv);
    }
}
