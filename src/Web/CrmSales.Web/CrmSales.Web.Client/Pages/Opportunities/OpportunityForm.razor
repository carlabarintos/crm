@page "/opportunities/new"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>New Opportunity</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/opportunities">Opportunities</a></li>
        <li class="breadcrumb-item active">New</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Main form -->
    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Opportunity Details</h5></div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="name" placeholder="Opportunity name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Account Name <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="accountName" placeholder="Company / Account" />
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Estimated Value <span class="text-danger">*</span></label>
                        <input class="form-control" type="number" step="0.01" @bind="estimatedValue" />
                    </div>
                    <div class="col">
                        <label class="form-label">Currency</label>
                        <select class="form-select" @bind="currency">
                            <option>PHP</option>
                            <option>USD</option>
                            <option>EUR</option>
                            <option>GBP</option>
                            <option>AUD</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Expected Close Date</label>
                    <input class="form-control" type="date" @bind="expectedCloseDate" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" @bind="description" rows="3" placeholder="Optional notes"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Owner <span class="text-danger">*</span></label>
                    @if (isSalesRep)
                    {
                        <input class="form-control" value="You" disabled />
                    }
                    else
                    {
                        <UserCombobox Value="selectedOwner" ValueChanged="u => selectedOwner = u" />
                    }
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Create Opportunity
                </button>
                <a href="/opportunities" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>

    <!-- Contact panel -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Contact</h6>
                @if (!creatingContact)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => creatingContact = true">+ New Contact</button>
                }
            </div>
            <div class="card-body">
                @if (!creatingContact)
                {
                    <!-- Searchable contact combobox -->
                    @if (selectedContact is not null)
                    {
                        <!-- Selected chip -->
                        <div class="contact-chip">
                            <div class="contact-avatar-sm">@selectedContact.FirstName[0]@selectedContact.LastName[0]</div>
                            <div class="contact-chip-body">
                                <div class="contact-chip-name">@selectedContact.FullName</div>
                                @if (selectedContact.Email is not null)
                                {
                                    <div class="contact-chip-sub">@selectedContact.Email</div>
                                }
                                @if (selectedContact.Company is not null)
                                {
                                    <div class="contact-chip-sub">@selectedContact.Company</div>
                                }
                            </div>
                            <button type="button" class="contact-chip-clear" @onclick="ClearContact" title="Remove contact">
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 2l10 10M12 2L2 12"/></svg>
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Search input + dropdown -->
                        <div class="contact-combobox" @onclick:stopPropagation>
                            <div class="contact-combobox-input-wrap">
                                <svg class="contact-search-icon" width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="#9CA3AF" stroke-width="1.5"><circle cx="6" cy="6" r="4.5"/><path d="M9.5 9.5l3 3" stroke-linecap="round"/></svg>
                                <input class="form-control form-control-sm contact-combobox-input"
                                       placeholder="Search contacts by name, email, or company…"
                                       value="@_contactSearch"
                                       @oninput="OnContactSearchInput"
                                       @onfocus="OnContactSearchFocus"
                                       @onblur="OnContactSearchBlur"
                                       autocomplete="off" />
                                @if (_contactSearchLoading)
                                {
                                    <span class="contact-search-spinner spinner-border spinner-border-sm"></span>
                                }
                            </div>

                            @if (_dropdownOpen)
                            {
                                <div class="contact-dropdown" @ref="_dropdownRef" @onscroll="OnDropdownScroll">
                                    @if (_contactResults.Any())
                                    {
                                        @foreach (var c in _contactResults)
                                        {
                                            var captured = c;
                                            <div class="contact-dropdown-item" @onmousedown="() => SelectContact(captured)">
                                                <div class="contact-avatar-xs">@c.FirstName[0]@c.LastName[0]</div>
                                                <div class="contact-dropdown-item-body">
                                                    <div class="contact-dropdown-name">@c.FullName</div>
                                                    @if (c.Company is not null || c.Email is not null)
                                                    {
                                                        <div class="contact-dropdown-sub">@(c.Company ?? c.Email)</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (_contactLoadingMore)
                                        {
                                            <div class="contact-dropdown-loading-more">
                                                <span class="spinner-border spinner-border-sm text-secondary"></span>
                                            </div>
                                        }
                                    }
                                    else if (!_contactSearchLoading)
                                    {
                                        <div class="contact-dropdown-empty">
                                            @if (string.IsNullOrWhiteSpace(_contactSearch))
                                            {
                                                <span>No contacts yet</span>
                                            }
                                            else
                                            {
                                                <span>No contacts match "<strong>@_contactSearch</strong>"</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Manual entry fallback -->
                        <div class="mt-2">
                            <label class="form-label form-label-sm text-muted">Or enter manually</label>
                            <input class="form-control form-control-sm" @bind="contactName" placeholder="Contact name (required)" />
                            <input class="form-control form-control-sm mt-1" type="email" @bind="contactEmail" placeholder="Email (optional)" />
                            <input class="form-control form-control-sm mt-1" @bind="contactPhone" placeholder="Phone (optional)" />
                        </div>
                    }
                }
                else
                {
                    <!-- Inline create contact form -->
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <input class="form-control form-control-sm" @bind="newContactFirst" placeholder="First name *" />
                        </div>
                        <div class="col">
                            <input class="form-control form-control-sm" @bind="newContactLast" placeholder="Last name *" />
                        </div>
                    </div>
                    <input class="form-control form-control-sm mb-2" type="email" @bind="newContactEmail" placeholder="Email" />
                    <input class="form-control form-control-sm mb-2" @bind="newContactPhone" placeholder="Phone" />
                    <input class="form-control form-control-sm mb-2" @bind="newContactCompany" placeholder="Company" />
                    <input class="form-control form-control-sm mb-2" @bind="newContactJobTitle" placeholder="Job title" />
                    @if (!string.IsNullOrEmpty(contactCreateError))
                    {
                        <div class="text-danger small mb-1">@contactCreateError</div>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="CreateContact" disabled="@creatingContactSaving">
                            @if (creatingContactSaving) { <span class="spinner-border spinner-border-sm"></span> } else { <span>Save Contact</span> }
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => { creatingContact = false; contactCreateError = null; }">Cancel</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* ── Contact avatars ───────────────────────────── */
    .contact-avatar-sm {
        width: 28px; height: 28px; border-radius: 50%;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 700; color: #fff; flex-shrink: 0;
        text-transform: uppercase;
    }
    .contact-avatar-xs {
        width: 24px; height: 24px; border-radius: 50%;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        display: flex; align-items: center; justify-content: center;
        font-size: 9px; font-weight: 700; color: #fff; flex-shrink: 0;
        text-transform: uppercase;
    }

    /* ── Selected chip ──────────────────────────────── */
    .contact-chip {
        display: flex; align-items: flex-start; gap: .6rem;
        padding: .6rem .75rem; border-radius: 10px;
        border: 1px solid #D1FAE5; background: #F0FDF4;
    }
    .contact-chip-body { flex: 1; min-width: 0; }
    .contact-chip-name { font-size: 13px; font-weight: 600; color: #111827; }
    .contact-chip-sub  { font-size: 11.5px; color: #6B7280; }
    .contact-chip-clear {
        background: none; border: none; padding: 0; cursor: pointer;
        color: #9CA3AF; flex-shrink: 0; margin-top: 1px;
        transition: color .15s;
    }
    .contact-chip-clear:hover { color: #EF4444; }

    /* ── Combobox container ─────────────────────────── */
    .contact-combobox { position: relative; }
    .contact-combobox-input-wrap { position: relative; }
    .contact-search-icon {
        position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
        pointer-events: none; z-index: 1;
    }
    .contact-combobox-input {
        padding-left: 28px !important;
        padding-right: 28px !important;
    }
    .contact-search-spinner {
        position: absolute; right: 9px; top: 50%; transform: translateY(-50%);
        color: #9CA3AF;
    }

    /* ── Dropdown panel ─────────────────────────────── */
    .contact-dropdown {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 200;
        background: #fff; border: 1px solid #E5E7EB; border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,.10);
        max-height: 240px; overflow-y: auto;
    }
    .contact-dropdown-item {
        display: flex; align-items: center; gap: .6rem;
        padding: .5rem .75rem; cursor: pointer;
        border-bottom: 1px solid #F9FAFB;
        transition: background .1s;
    }
    .contact-dropdown-item:last-child { border-bottom: none; }
    .contact-dropdown-item:hover { background: #F5F3FF; }
    .contact-dropdown-item-body { min-width: 0; }
    .contact-dropdown-name { font-size: 13px; font-weight: 600; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .contact-dropdown-sub  { font-size: 11px; color: #9CA3AF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .contact-dropdown-empty {
        padding: .875rem .75rem; font-size: 12.5px; color: #9CA3AF; text-align: center;
    }
    .contact-dropdown-loading-more {
        display: flex; justify-content: center; padding: .5rem;
        border-top: 1px solid #F3F4F6;
    }
</style>

@code {
    // Opportunity fields
    private string name = "";
    private string accountName = "";
    private string contactName = "";
    private string? contactEmail;
    private string? contactPhone;
    private decimal estimatedValue;
    private string currency = "PHP";
    private DateTime? expectedCloseDate = DateTime.Today.AddDays(2);
    private string? description;
    private UserDto? selectedOwner;
    private string _salesRepId = "";

    // Contact combobox state
    private string _contactSearch = "";
    private List<ContactDto> _contactResults = [];
    private string? _contactCursor;
    private bool _contactHasMore;
    private bool _contactSearchLoading;
    private bool _contactLoadingMore;
    private bool _dropdownOpen;
    private System.Threading.CancellationTokenSource? _searchCts;
    private ContactDto? selectedContact;
    private ElementReference _dropdownRef;

    // Inline contact creation
    private bool creatingContact;
    private bool creatingContactSaving;
    private string? contactCreateError;
    private string newContactFirst = "", newContactLast = "";
    private string? newContactEmail, newContactPhone, newContactCompany, newContactJobTitle;

    private bool isSalesRep;
    private bool saving;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();

        isSalesRep = auth.User.IsInRole("SalesRep");

        if (isSalesRep)
        {
            _salesRepId = auth.User.FindFirst("sub")?.Value
                ?? auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }
        else
        {
            var currentEmail = auth.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                ?? auth.User.FindFirst("email")?.Value;
            var users = await Api.GetUsersAsync();
            selectedOwner = users?.FirstOrDefault(u =>
                string.Equals(u.Email, currentEmail, StringComparison.OrdinalIgnoreCase))
                ?? users?.FirstOrDefault();
        }
    }

    // ── Contact combobox ──────────────────────────────────────────────────

    private async Task OnContactSearchInput(ChangeEventArgs e)
    {
        _contactSearch = e.Value?.ToString() ?? "";
        _contactCursor = null;
        _contactResults = [];
        _contactHasMore = false;
        _dropdownOpen = true;

        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;

        await Task.Delay(260);
        if (token.IsCancellationRequested) return;

        await FetchContacts(reset: true, ct: token);
    }

    private async Task OnContactSearchFocus()
    {
        _dropdownOpen = true;
        if (!_contactResults.Any() && !_contactSearchLoading)
            await FetchContacts(reset: true);
    }

    private async Task OnContactSearchBlur()
    {
        // Delay so @onmousedown on dropdown items fires first
        await Task.Delay(180);
        _dropdownOpen = false;
    }

    private async Task FetchContacts(bool reset = false, System.Threading.CancellationToken ct = default)
    {
        if (reset)
        {
            _contactCursor = null;
            _contactResults = [];
            _contactSearchLoading = true;
        }
        else
        {
            _contactLoadingMore = true;
        }

        try
        {
            var result = await Api.GetContactsAsync(
                string.IsNullOrWhiteSpace(_contactSearch) ? null : _contactSearch,
                limit: 5, cursor: _contactCursor);

            if (ct.IsCancellationRequested) return;

            _contactResults.AddRange(result?.Items ?? []);
            _contactCursor = result?.NextCursor;
            _contactHasMore = result?.HasMore ?? false;
        }
        finally
        {
            _contactSearchLoading = false;
            _contactLoadingMore = false;
            StateHasChanged();
        }
    }

    private async Task LoadMoreContacts() => await FetchContacts(reset: false);

    private async Task OnDropdownScroll()
    {
        if (!_contactHasMore || _contactLoadingMore || _contactSearchLoading) return;
        var nearBottom = await JS.InvokeAsync<bool>("isScrolledNearBottom", _dropdownRef, 40);
        if (nearBottom) await LoadMoreContacts();
    }

    private void SelectContact(ContactDto c)
    {
        selectedContact = c;
        contactName  = c.FullName;
        contactEmail = c.Email;
        contactPhone = c.Phone;
        if (string.IsNullOrWhiteSpace(accountName) && c.Company is not null)
            accountName = c.Company;

        _dropdownOpen = false;
        _contactSearch = "";
        _contactResults = [];
    }

    private void ClearContact()
    {
        selectedContact = null;
        contactName = "";
        contactEmail = null;
        contactPhone = null;
        _contactSearch = "";
        _contactResults = [];
        _contactCursor = null;
        _contactHasMore = false;
    }

    // ── Inline contact creation ───────────────────────────────────────────

    private async Task CreateContact()
    {
        contactCreateError = null;
        if (string.IsNullOrWhiteSpace(newContactFirst) || string.IsNullOrWhiteSpace(newContactLast))
        { contactCreateError = "First and last name are required."; return; }

        creatingContactSaving = true;
        try
        {
            var resp = await Api.CreateContactAsync(new
            {
                FirstName = newContactFirst, LastName = newContactLast,
                Email = newContactEmail, Phone = newContactPhone,
                Company = newContactCompany, JobTitle = newContactJobTitle,
                Notes = (string?)null
            });

            if (resp.IsSuccessStatusCode)
            {
                // Fetch the newly created contact by searching its name to get the Id
                var results = await Api.GetContactsAsync(newContactFirst + " " + newContactLast, limit: 5);
                var created = results?.Items.FirstOrDefault(c =>
                    c.FirstName == newContactFirst && c.LastName == newContactLast);

                if (created is not null)
                    SelectContact(created);
                else
                {
                    // Fallback: populate manually
                    contactName = $"{newContactFirst} {newContactLast}".Trim();
                    contactEmail = newContactEmail;
                    contactPhone = newContactPhone;
                }

                creatingContact = false;
                newContactFirst = ""; newContactLast = "";
                newContactEmail = null; newContactPhone = null;
                newContactCompany = null; newContactJobTitle = null;
            }
            else
            {
                contactCreateError = await resp.Content.ReadAsStringAsync();
            }
        }
        finally { creatingContactSaving = false; }
    }

    private async Task Save()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(accountName) || estimatedValue <= 0)
        { error = "Name, Account Name and a positive Estimated Value are required."; return; }

        Guid ownerGuid;
        if (isSalesRep)
        {
            if (!Guid.TryParse(_salesRepId, out ownerGuid)) { error = "Owner not resolved."; return; }
        }
        else
        {
            if (selectedOwner is null) { error = "Please select an owner."; return; }
            ownerGuid = selectedOwner.Id;
        }

        var resolvedContactName = selectedContact?.FullName ?? contactName;
        if (string.IsNullOrWhiteSpace(resolvedContactName))
        { error = "Please select or enter a contact name."; return; }

        Guid? contactId = selectedContact?.Id;

        saving = true;
        try
        {
            var resp = await Api.CreateOpportunityAsync(new
            {
                Name = name,
                AccountName = accountName,
                ContactId = contactId,
                ContactName = resolvedContactName,
                ContactEmail = contactEmail,
                ContactPhone = contactPhone,
                EstimatedValue = estimatedValue,
                Currency = currency,
                ExpectedCloseDate = expectedCloseDate,
                Description = description,
                OwnerId = ownerGuid
            });

            if (resp.IsSuccessStatusCode)
                Nav.NavigateTo("/opportunities");
            else
                error = await resp.Content.ReadAsStringAsync();
        }
        finally { saving = false; }
    }
}
