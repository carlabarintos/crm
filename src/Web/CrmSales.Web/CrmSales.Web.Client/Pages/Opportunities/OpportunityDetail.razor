@page "/opportunities/{Id:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>@(opp?.Name ?? "Opportunity")</PageTitle>

@if (opp is null && error is null)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (opp is not null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/opportunities">Opportunities</a></li>
            <li class="breadcrumb-item active">@opp.Name</li>
        </ol>
    </nav>

    <!-- Stage stepper -->
    <div class="card mb-4 stagger-1">
        <div class="card-body py-3">
            <div class="stage-stepper">
                @foreach (var (stage, idx) in Stages.Select((s, i) => (s, i)))
                {
                    var stepState = GetStepState(stage);
                    <div class="stage-step @stepState" @onclick="() => QuickStage(stage)">
                        <div class="step-circle">
                            @if (stepState == "done")
                            {
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            }
                            else
                            {
                                <span>@(idx + 1)</span>
                            }
                        </div>
                        <div class="step-label">@FormatStage(stage)</div>
                    </div>
                    @if (idx < Stages.Length - 1)
                    {
                        <div class="step-connector @(GetStepIndex(opp.Stage) > idx ? "done" : "")"></div>
                    }
                }
            </div>
            @if (opp.Stage is "ClosedWon" or "ClosedLost")
            {
                <div class="text-center mt-3">
                    <span class="badge @(opp.Stage == "ClosedWon" ? "badge-soft-success" : "badge-soft-danger")" style="font-size:13px;padding:.4em 1em">
                        @(opp.Stage == "ClosedWon" ? "Won" : "Lost")
                    </span>
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Main info -->
        <div class="col-md-8">
            <div class="card mb-4 stagger-2">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@opp.Name</h5>
                    <span class="badge @GetStageBadgeClass(opp.Stage)">@FormatStage(opp.Stage)</span>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Account</dt>
                        <dd class="col-sm-9">@opp.AccountName</dd>

                        <dt class="col-sm-3">Contact</dt>
                        <dd class="col-sm-9">
                            @opp.ContactName
                            @if (!string.IsNullOrEmpty(opp.ContactEmail))
                            {
                                <br /><a href="mailto:@opp.ContactEmail" class="text-muted small">@opp.ContactEmail</a>
                            }
                            @if (!string.IsNullOrEmpty(opp.ContactPhone))
                            {
                                <br /><span class="text-muted small">@opp.ContactPhone</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Value</dt>
                        <dd class="col-sm-9">
                            <span class="fw-bold gradient-text" style="font-size:1.15rem">@opp.Currency @opp.EstimatedValue.ToString("N2")</span>
                        </dd>

                        <dt class="col-sm-3">Probability</dt>
                        <dd class="col-sm-9">
                            <div class="d-flex align-items-center gap-2">
                                <div class="flex-grow-1" style="height:6px;background:#E5E7EB;border-radius:99px;overflow:hidden;max-width:180px">
                                    <div style="width:@opp.Probability%;height:100%;background:linear-gradient(90deg,#6366f1,#8b5cf6);border-radius:99px;transition:width .4s"></div>
                                </div>
                                <span class="small fw-semibold text-muted">@opp.Probability%</span>
                            </div>
                        </dd>

                        <dt class="col-sm-3">Close Date</dt>
                        <dd class="col-sm-9">@(opp.ExpectedCloseDate?.ToString("MMM dd, yyyy") ?? "—")</dd>

                        @if (!string.IsNullOrEmpty(opp.Description))
                        {
                            <dt class="col-sm-3">Description</dt>
                            <dd class="col-sm-9">@opp.Description</dd>
                        }

                        <dt class="col-sm-3">Created</dt>
                        <dd class="col-sm-9 text-muted">@opp.CreatedAt.ToString("MMM dd, yyyy")</dd>
                    </dl>
                </div>
            </div>

            <!-- Activities -->
            <div class="card stagger-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Activities</h6>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => showActivityForm = !showActivityForm">+ Add Activity</button>
                </div>
                @if (showActivityForm)
                {
                    <div class="card-body border-bottom">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <select class="form-select form-select-sm" @bind="actType">
                                    <option value="Call">Call</option>
                                    <option value="Email">Email</option>
                                    <option value="Meeting">Meeting</option>
                                    <option value="Demo">Demo</option>
                                    <option value="Note">Note</option>
                                </select>
                            </div>
                            <div class="col-md-7">
                                <input class="form-control form-control-sm" @bind="actNotes" placeholder="Notes..." />
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-sm btn-primary w-100" @onclick="AddActivity" disabled="@actSaving">
                                    @if (actSaving) { <span class="spinner-border spinner-border-sm"></span> } else { <span>Save</span> }
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(actError)) { <div class="text-danger small mt-1">@actError</div> }
                    </div>
                }
                <ul class="list-group list-group-flush">
                    @if (!opp.Activities.Any())
                    {
                        <li class="list-group-item text-center text-muted py-4" style="font-size:13px">No activities yet.</li>
                    }
                    @foreach (var a in opp.Activities.OrderByDescending(a => a.OccurredAt))
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge badge-soft-neutral me-2">@a.Type</span>
                                    <span style="font-size:13px">@a.Notes</span>
                                </div>
                                <small class="text-muted flex-shrink-0 ms-3">@a.OccurredAt.ToString("MMM dd, HH:mm")</small>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-4 stagger-4">

            <!-- Convert to Quote — always visible, enabled at Proposal/Negotiation -->
            @{
                var canConvert = CanConvertToQuote(opp.Stage);
                var isClosed = opp.Stage is "ClosedWon" or "ClosedLost";
            }
            <div class="card mb-3" style="border-color:@(canConvert ? "#c7d2fe" : "#E5E7EB");background:@(canConvert ? "linear-gradient(135deg,#fafaff,#f5f3ff)" : "#fafafa")">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <div style="width:40px;height:40px;border-radius:10px;background:@(canConvert ? "linear-gradient(135deg,#6366f1,#8b5cf6)" : "#E5E7EB");display:flex;align-items:center;justify-content:center;margin:0 auto">
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="@(canConvert ? "white" : "#9CA3AF")" stroke-width="1.8">
                                <rect x="2" y="2" width="14" height="16" rx="2"/>
                                <path d="M6 7h6M6 10h6M6 13h4" stroke-linecap="round"/>
                            </svg>
                        </div>
                    </div>
                    @if (canConvert)
                    {
                        <div class="fw-semibold mb-1" style="font-size:14px;color:#111827">Ready to quote?</div>
                        <div class="text-muted mb-3" style="font-size:12px">Create a quote from this opportunity</div>
                        <a href="/quotes/new?opportunityId=@opp.Id" class="btn btn-primary btn-sm w-100">Convert to Quote</a>
                    }
                    else if (isClosed)
                    {
                        <div class="fw-semibold mb-1" style="font-size:14px;color:#6B7280">Deal closed</div>
                        <div class="text-muted" style="font-size:12px">This opportunity is @FormatStage(opp.Stage)</div>
                    }
                    else
                    {
                        <div class="fw-semibold mb-1" style="font-size:14px;color:#111827">Convert to Quote</div>
                        <div class="text-muted mb-3" style="font-size:12px">Move to <strong>Proposal</strong> to create a quote</div>
                        <button class="btn btn-secondary btn-sm w-100" disabled>Convert to Quote</button>
                    }
                </div>
            </div>

            <!-- Change Stage -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0">Move Stage</h6></div>
                <div class="card-body">
                    <div class="stage-btn-list">
                        @foreach (var stage in AllStages)
                        {
                            var isCurrent = opp.Stage == stage;
                            <button class="stage-btn @(isCurrent ? "active" : "")"
                                    @onclick="() => QuickStage(stage)"
                                    disabled="@(isCurrent || stageSaving)">
                                <span class="stage-btn-dot" style="background:@GetStageColor(stage)"></span>
                                @FormatStage(stage)
                                @if (isCurrent) { <span class="ms-auto badge badge-soft-primary" style="font-size:10px">Current</span> }
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(stageError)) { <div class="text-danger small mt-2">@stageError</div> }
                    @if (!string.IsNullOrEmpty(stageSuccess)) { <div class="text-success small mt-2">@stageSuccess</div> }
                </div>
            </div>

            <!-- Quick links -->
            <div class="card">
                <div class="card-body d-flex flex-column gap-2">
                    <a href="/quotes?opportunityId=@opp.Id" class="btn btn-outline-secondary btn-sm">View Linked Quotes</a>
                    <a href="/opportunities" class="btn btn-outline-secondary btn-sm">Back to List</a>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* Stage stepper */
    .stage-stepper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding: .25rem 0;
    }
    .stage-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .35rem;
        cursor: pointer;
        flex-shrink: 0;
    }
    .step-circle {
        width: 30px; height: 30px; border-radius: 50%;
        border: 2px solid #E5E7EB;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: #9CA3AF;
        transition: all .2s;
    }
    .step-label {
        font-size: 11px; font-weight: 500; color: #9CA3AF;
        white-space: nowrap;
        transition: color .2s;
    }
    .stage-step.done .step-circle { background: #6366f1; border-color: #6366f1; color: #fff; }
    .stage-step.done .step-label { color: #6366f1; }
    .stage-step.current .step-circle { background: #fff; border-color: #6366f1; color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.15); }
    .stage-step.current .step-label { color: #4338CA; font-weight: 700; }
    .stage-step:hover:not(.current) .step-circle { border-color: #a5b4fc; color: #6366f1; }
    .step-connector {
        flex: 1;
        height: 2px;
        background: #E5E7EB;
        min-width: 24px;
        max-width: 60px;
        transition: background .2s;
        margin-bottom: 18px;
    }
    .step-connector.done { background: #6366f1; }

    /* Stage button list */
    .stage-btn-list { display: flex; flex-direction: column; gap: .3rem; }
    .stage-btn {
        display: flex; align-items: center; gap: .5rem;
        padding: .45rem .75rem;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        background: #fff;
        font-size: 13px; font-weight: 500; color: #374151;
        cursor: pointer;
        transition: all .15s;
        text-align: left; width: 100%;
    }
    .stage-btn:hover:not(:disabled) { background: #F8FAFC; border-color: #c7d2fe; color: #4338CA; }
    .stage-btn.active { background: #EEF2FF; border-color: #c7d2fe; color: #4338CA; font-weight: 600; }
    .stage-btn:disabled:not(.active) { opacity: .4; cursor: not-allowed; }
    .stage-btn-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private OpportunityDetailDto? opp;
    private string? error;

    private bool stageSaving;
    private string? stageError;
    private string? stageSuccess;

    private bool showActivityForm;
    private string actType = "Call";
    private string actNotes = "";
    private bool actSaving;
    private string? actError;

    // Ordered pipeline stages (not including closed)
    private static readonly string[] Stages = ["Prospecting", "Qualification", "Proposal"];
    private static readonly string[] AllStages = ["Prospecting", "Qualification", "Proposal", "ClosedWon", "ClosedLost"];

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { opp = await Api.GetOpportunityAsync(Id); }
        catch { error = "Failed to load opportunity."; }
    }

    private async Task QuickStage(string stage)
    {
        if (opp is null || opp.Stage == stage) return;
        stageError = null; stageSuccess = null;
        stageSaving = true;
        try
        {
            var resp = await Api.ChangeOpportunityStageAsync(Id, stage);
            if (resp.IsSuccessStatusCode) { stageSuccess = $"Moved to {FormatStage(stage)}."; await Load(); }
            else stageError = await resp.Content.ReadAsStringAsync();
        }
        finally { stageSaving = false; }
    }

    private async Task AddActivity()
    {
        actError = null;
        if (string.IsNullOrWhiteSpace(actNotes)) { actError = "Notes are required."; return; }
        actSaving = true;
        try
        {
            var resp = await Api.AddActivityAsync(Id, new { Type = actType, Notes = actNotes, PerformedById = Guid.Empty });
            if (resp.IsSuccessStatusCode) { actNotes = ""; showActivityForm = false; await Load(); }
            else actError = await resp.Content.ReadAsStringAsync();
        }
        finally { actSaving = false; }
    }

    private static bool CanConvertToQuote(string stage) =>
        stage is "Proposal";

    private string GetStepState(string stage)
    {
        if (opp is null) return "";
        var current = GetStepIndex(opp.Stage);
        var idx = Array.IndexOf(Stages, stage);
        if (idx < 0) return "";
        if (idx < current) return "done";
        if (idx == current) return "current";
        return "";
    }

    private int GetStepIndex(string stage) => Array.IndexOf(Stages, stage);

    private static string FormatStage(string stage) => stage switch
    {
        "ClosedWon"  => "Closed Won",
        "ClosedLost" => "Closed Lost",
        _ => stage
    };

    private static string GetStageBadgeClass(string stage) => stage switch
    {
        "ClosedWon"    => "badge-soft-success",
        "ClosedLost"   => "badge-soft-danger",
        "Proposal"     => "badge-soft-info",
        _              => "badge-soft-neutral"
    };

    private static string GetStageColor(string stage) => stage switch
    {
        "Prospecting"   => "#94A3B8",
        "Qualification" => "#F59E0B",
        "Proposal"      => "#3B82F6",
        "ClosedWon"     => "#10B981",
        "ClosedLost"    => "#EF4444",
        _ => "#9CA3AF"
    };
}
