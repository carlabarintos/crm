@page "/opportunities"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using CrmSales.Web.Client.Services
@inject CrmApiClient Api
@inject IJSRuntime JS

<PageTitle>Opportunities — CRM Sales</PageTitle>

<!-- Page header -->
<div class="page-header stagger-1">
    <div>
        <p class="page-header-meta">Sales Pipeline</p>
        <h1>Opportunities</h1>
    </div>
    <div class="d-flex gap-2">
        @if (opportunities is not null && opportunities.Any())
        {
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportCsv">Export CSV</button>
        }
        <a href="/opportunities/new" class="btn btn-primary">+ New Opportunity</a>
    </div>
</div>

<!-- Summary cards -->
@if (_summary is not null)
{
    <button type="button" class="mob-section-btn @(_statsOpen ? "open" : "")" @onclick="() => _statsOpen = !_statsOpen">
        <span>Summary</span>
        <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
    </button>
    <div class="mob-collapse @(_statsOpen ? "open" : "")">
    <div class="row g-3 mb-4 stagger-2">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Open Pipeline</div>
                <div class="stat-card-value text-primary">@FormatValue(_summary.PipelineValue, _summary.Currency)</div>
                <div class="stat-card-sub">@_summary.OpenCount open</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Weighted Value</div>
                <div class="stat-card-value" style="color:#7C3AED">@FormatValue(_summary.WeightedValue, _summary.Currency)</div>
                <div class="stat-card-sub">by probability</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Win Rate</div>
                <div class="stat-card-value text-success">@_summary.WinRate</div>
                <div class="stat-card-sub">@_summary.WonCount won · @_summary.LostCount lost</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-card-label">Total</div>
                <div class="stat-card-value" style="color:#111827">@_summary.TotalCount</div>
                <div class="stat-card-sub">all opportunities</div>
            </div>
        </div>
    </div>
    </div>
}

<!-- Filters -->
<button type="button" class="mob-section-btn @(_filtersOpen ? "open" : "")" @onclick="() => _filtersOpen = !_filtersOpen">
    <span>Filters</span>
    <svg class="mob-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l4 4 4-4"/></svg>
</button>
<div class="mob-collapse @(_filtersOpen ? "open" : "")">
<div class="d-flex gap-2 mb-4 stagger-3" style="flex-wrap:wrap">
    <div style="position:relative;flex:1;min-width:200px;max-width:320px">
        <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9CA3AF;pointer-events:none"
             width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="6" cy="6" r="4.5"/><path d="M9.5 9.5l3 3" stroke-linecap="round"/>
        </svg>
        <input class="form-control" style="padding-left:30px" placeholder="Search opportunities…"
               @bind="searchTerm" @onkeyup="OnSearchKey" />
    </div>
    <select class="form-select" style="width:auto;min-width:150px" @bind="selectedStage" @bind:after="OnFilterChanged">
        <option value="">All Stages</option>
        <option value="Prospecting">Prospecting</option>
        <option value="Qualification">Qualification</option>
        <option value="NeedsAnalysis">Needs Analysis</option>
        <option value="Proposal">Proposal</option>
        <option value="Negotiation">Negotiation</option>
        <option value="ClosedWon">Closed Won</option>
        <option value="ClosedLost">Closed Lost</option>
    </select>
</div>
</div>

@if (opportunities is null && !isLoadingMore)
{
    <!-- Skeleton table -->
    <div class="table-responsive">
        <table class="table">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Account</th>
                    <th>Stage</th>
                    <th>Value</th>
                    <th>Probability</th>
                    <th>Close Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < 7; i++)
                {
                    var delay = i * 60;
                    <tr>
                        <td><div class="opp-sk opp-sk-name" style="animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:100px;height:13px;animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:80px;height:20px;border-radius:99px;animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:72px;height:13px;animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:80px;height:8px;border-radius:99px;animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:88px;height:13px;animation-delay:@(delay)ms"></div></td>
                        <td><div class="opp-sk" style="width:48px;height:26px;border-radius:8px;animation-delay:@(delay)ms"></div></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!opportunities.Any() && !isLoadingMore)
{
    <div class="opp-empty stagger-4">
        <div class="opp-empty-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#9CA3AF" stroke-width="1.5">
                <path d="M2 21L8 13L13.5 17L19 10L26 4" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="26" cy="4" r="2.5" fill="#9CA3AF" stroke="none"/>
            </svg>
        </div>
        <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:.35rem">No opportunities found</div>
        <div style="font-size:13px;color:#9CA3AF;margin-bottom:1.25rem">
            @(string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(selectedStage)
                ? "Start by creating your first opportunity."
                : "Try adjusting your filters.")
        </div>
        @if (string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(selectedStage))
        {
            <a href="/opportunities/new" class="btn btn-primary btn-sm">+ New Opportunity</a>
        }
    </div>
}
else
{
    <div class="table-responsive stagger-4">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Account</th>
                    <th>Stage</th>
                    <th>Value</th>
                    <th>Probability</th>
                    <th>Close Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var opp in opportunities)
                {
                    <tr>
                        <td>
                            <a href="/opportunities/@opp.Id" class="opp-name-link">@opp.Name</a>
                        </td>
                        <td style="color:#6B7280">@opp.AccountName</td>
                        <td>
                            <span class="badge @GetStageBadge(opp.Stage)">@FormatStage(opp.Stage)</span>
                        </td>
                        <td style="font-weight:600;color:#111827;font-variant-numeric:tabular-nums">
                            @FormatValue(opp.EstimatedValue, opp.Currency)
                        </td>
                        <td>
                            <div class="opp-prob">
                                <div class="progress" style="width:70px;flex-shrink:0">
                                    <div class="progress-bar @GetProbBarClass(opp.Probability)"
                                         style="width:@opp.Probability%"></div>
                                </div>
                                <span class="opp-prob-label">@opp.Probability%</span>
                            </div>
                        </td>
                        <td style="color:#6B7280;font-size:12.5px">
                            @(opp.ExpectedCloseDate?.ToString("MMM d, yyyy") ?? "—")
                        </td>
                        <td>
                            <a href="/opportunities/@opp.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (hasMore)
{
    <div class="text-center py-3">
        <button class="btn btn-outline-primary" @onclick="LoadMore" disabled="@isLoadingMore">
            @if (isLoadingMore) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Load More
        </button>
    </div>
}

<style>
    .stat-card {
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }
    .stat-card-label {
        font-size: 11.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #9CA3AF;
        margin-bottom: .3rem;
    }
    .stat-card-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
        margin-bottom: .2rem;
    }
    .stat-card-sub {
        font-size: 11.5px;
        color: #9CA3AF;
    }

    @@keyframes opp-shimmer {
        0%   { background-position: -400px 0; }
        100% { background-position:  400px 0; }
    }
    .opp-sk {
        background: linear-gradient(90deg, #F3F4F6 25%, #EAECF0 50%, #F3F4F6 75%);
        background-size: 800px 100%;
        animation: opp-shimmer 1.6s ease-in-out infinite;
        border-radius: 5px;
        display: inline-block;
    }
    .opp-sk-name { width: 160px; height: 14px; }

    .opp-name-link {
        font-weight: 600;
        color: #111827;
        text-decoration: none;
    }
    .opp-name-link:hover { color: #4F46E5; text-decoration: none; }

    .opp-prob {
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .opp-prob-label {
        font-size: 11.5px;
        font-weight: 600;
        color: #6B7280;
        min-width: 26px;
    }

    .opp-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }
    .opp-empty-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        background: #F3F4F6;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
    }
</style>

@code {
    private List<OpportunityDto> opportunities = [];
    private OpportunitySummaryDto? _summary;
    private string searchTerm = "";
    private string selectedStage = "";
    private string? cursor;
    private bool hasMore;
    private bool isLoadingMore;
    private bool _statsOpen = true;
    private bool _filtersOpen = true;

    private async Task ExportCsv()
    {
        if (opportunities is null) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Name,Account,Stage,Value,Currency,Probability,Close Date");
        foreach (var o in opportunities)
            sb.AppendLine($"\"{o.Name}\",\"{o.AccountName}\",\"{o.Stage}\",{o.EstimatedValue},\"{o.Currency}\",{o.Probability},\"{o.ExpectedCloseDate?.ToString("yyyy-MM-dd") ?? ""}\"");
        await JS.InvokeVoidAsync("downloadCsv", $"opportunities_{DateTime.Today:yyyyMMdd}.csv", sb.ToString());
    }

    protected override async Task OnInitializedAsync()
    {
        var summaryTask = Api.GetOpportunitySummaryAsync();
        await LoadOpportunities();
        _summary = await summaryTask;
    }

    private async Task Search()
    {
        cursor = null;
        await LoadOpportunities();
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task OnFilterChanged()
    {
        await Search();
    }

    private async Task LoadOpportunities()
    {
        var result = await Api.GetOpportunitiesAsync(
            string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
            string.IsNullOrEmpty(selectedStage) ? null : selectedStage,
            20, cursor);

        if (cursor is null)
            opportunities = result?.Items ?? [];
        else
            opportunities.AddRange(result?.Items ?? []);

        cursor = result?.NextCursor;
        hasMore = result?.HasMore ?? false;
    }

    private async Task LoadMore()
    {
        if (isLoadingMore || !hasMore) return;
        isLoadingMore = true;
        try
        {
            var result = await Api.GetOpportunitiesAsync(
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                string.IsNullOrEmpty(selectedStage) ? null : selectedStage,
                20, cursor);

            opportunities.AddRange(result?.Items ?? []);
            cursor = result?.NextCursor;
            hasMore = result?.HasMore ?? false;
        }
        finally
        {
            isLoadingMore = false;
        }
    }

    private static string GetStageBadge(string stage) => stage switch
    {
        "ClosedWon"      => "badge-soft-success",
        "ClosedLost"     => "badge-soft-danger",
        "Negotiation"    => "badge-soft-primary",
        "Proposal"       => "badge-soft-info",
        "Qualification"  => "badge-soft-warning",
        "NeedsAnalysis"  => "badge-soft-purple",
        _                => "badge-soft-neutral",
    };

    private static string GetProbBarClass(decimal prob) => prob >= 70 ? "bg-success"
        : prob >= 40 ? "bg-warning" : "";

    private static string FormatStage(string stage) => stage switch
    {
        "ClosedWon"     => "Closed Won",
        "ClosedLost"    => "Closed Lost",
        "NeedsAnalysis" => "Needs Analysis",
        _               => stage,
    };

    private static string FormatValue(decimal value, string currency)
    {
        var sym = currency switch
        {
            "PHP" => "₱", "USD" => "$", "EUR" => "€", "GBP" => "£", _ => currency + " "
        };
        return value >= 1_000_000 ? $"{sym}{value / 1_000_000:N1}M"
             : value >= 1_000     ? $"{sym}{value / 1_000:N1}K"
             : $"{sym}{value:N0}";
    }

}